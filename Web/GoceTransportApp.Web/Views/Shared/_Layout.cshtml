@using GoceTransportApp.Common
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="GoceTrans" />
    <link rel="apple-touch-icon" href="/images/no-organization-image.png" />
    <title>@this.ViewData["Title"] - @GlobalConstants.SystemName</title>
    <meta name="description" content="@(this.ViewData["MetaDescription"] ?? "Find bus routes, book tickets and manage transport across Bulgaria. GoceTrans — your trusted platform for intercity travel.")" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.gocetransport.com@(Context.Request.Path)" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@GlobalConstants.SystemName" />
    <meta property="og:title" content="@(this.ViewData["Title"] != null ? this.ViewData["Title"] + " - " + GlobalConstants.SystemName : GlobalConstants.SystemName)" />
    <meta property="og:description" content="@(this.ViewData["MetaDescription"] ?? "Find bus routes, book tickets and manage transport across Bulgaria.")" />
    <meta property="og:image" content="https://www.gocetransport.com/images/no-organization-image.png" />
    <meta property="og:url" content="https://www.gocetransport.com@(Context.Request.Path)" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@(this.ViewData["Title"] != null ? this.ViewData["Title"] + " - " + GlobalConstants.SystemName : GlobalConstants.SystemName)" />
    <meta name="twitter:description" content="@(this.ViewData["MetaDescription"] ?? "Find bus routes, book tickets and manage transport across Bulgaria.")" />
    <meta name="twitter:image" content="https://www.gocetransport.com/images/no-organization-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script>
        (function () {
            var theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>
</head>
<body class="d-flex flex-column min-vh-100 bg-body-tertiary">
    <!-- Header (Navbar) -->
    <header>
        <nav class="navbar navbar-expand-lg bg-body sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand fs-5 fw-bolder text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-bus-alt"></i> @GlobalConstants.SystemName
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
                        </li>

                        <li class="nav-item dropdown" id="exploreDropdownWrapper">
                            <a class="nav-link dropdown-toggle fw-semibold" href="#" id="exploreDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @Localizer["Explore"]
                            </a>
                            <ul class="dropdown-menu shadow border-0 rounded-3">
                                <li><a class="dropdown-item py-2" asp-area="" asp-controller="Route" asp-action="Index"><i class="fas fa-route me-2 text-primary"></i>@Localizer["Routes"]</a></li>
                                <li><a class="dropdown-item py-2" asp-area="" asp-controller="Schedule" asp-action="Index"><i class="fas fa-calendar-alt me-2 text-primary"></i>@Localizer["Schedules"]</a></li>
                                <li><a class="dropdown-item py-2" asp-area="" asp-controller="Ticket" asp-action="Index"><i class="fas fa-ticket-alt me-2 text-primary"></i>@Localizer["Tickets"]</a></li>
                                <li><hr class="dropdown-divider my-1" /></li>
                                <li><a class="dropdown-item py-2" asp-area="" asp-controller="Organization" asp-action="Index"><i class="fas fa-building me-2 text-primary"></i>@Localizer["Organizations"]</a></li>
                                <li><a class="dropdown-item py-2" asp-area="" asp-controller="City" asp-action="Index"><i class="fas fa-city me-2 text-primary"></i>@Localizer["Cities"]</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Home" asp-action="AboutUs">@Localizer["About Us"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="ContactForm" asp-action="Create">@Localizer["Contact Us"]</a>
                        </li>
                        <!-- Language selector — visible only in hamburger menu on mobile -->
                        <ul class="navbar-nav d-lg-none border-top pt-2 mt-2">
                            <partial name="_SelectLanguagePartial" />
                        </ul>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <a asp-area="" asp-controller="Schedule" asp-action="Index" class="btn btn-primary btn-sm rounded-pill px-3 fw-semibold d-none d-lg-inline-block">
                            <i class="fas fa-search me-1"></i>@Localizer["Find a Bus"]
                        </a>

                        <ul class="navbar-nav d-none d-lg-flex">
                            <partial name="_SelectLanguagePartial" />
                        </ul>

                        <partial name="_LoginPartial" />

                        <button id="darkModeToggle" class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center" title="Toggle dark mode" aria-label="Toggle dark mode" style="width:34px;height:34px;">
                            <i id="darkModeIcon" class="fas fa-moon"></i>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Toast container -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090">
        <partial name="_NotificationsPartial" />
    </div>

    <!-- Main Content -->
    <main class="flex-grow-1 py-5 page-fade-in">
        <div class="container">
            <partial name="_CookieConsentPartial" />

            @this.RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-5 mt-auto">
        <div class="container">
            <div class="row g-4">
                <!-- Column 1: Brand & Mission -->
                <div class="col-lg-4 col-md-6 mb-3">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="fas fa-bus-alt fs-4 text-primary"></i>
                        <span class="fs-5 fw-bold">@GlobalConstants.SystemName</span>
                    </div>
                    <p class="text-white-50 small mb-3">
                        @Localizer["Your trusted platform for discovering routes, booking tickets, and managing transport organizations across Bulgaria."]
                    </p>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-white-50 fs-5"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-white-50 fs-5"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-white-50 fs-5"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-white-50 fs-5"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>

                <!-- Column 2: For Passengers -->
                <div class="col-lg-2 col-md-6 col-6 mb-3">
                    <h6 class="fw-bold text-white mb-3">@Localizer["For Passengers"]</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="Schedule" asp-action="Search"><i class="fas fa-search me-1"></i>@Localizer["Find a Trip"]</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-ticket-alt me-1"></i>@Localizer["My Trips"]</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="Route" asp-action="Index"><i class="fas fa-route me-1"></i>@Localizer["Routes"]</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="ContactForm" asp-action="Create"><i class="fas fa-question-circle me-1"></i>@Localizer["Contact Us"]</a></li>
                    </ul>
                </div>

                <!-- Column 3: For Partners -->
                <div class="col-lg-3 col-md-6 col-6 mb-3">
                    <h6 class="fw-bold text-white mb-3">@Localizer["For Partners"]</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="Organization" asp-action="Create"><i class="fas fa-plus-circle me-1"></i>@Localizer["Register Organization"]</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="Organization" asp-action="Upgrade"><i class="fas fa-gem me-1"></i>@Localizer["Pricing & Plans"]</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="Organization" asp-action="UserOrganizations"><i class="fas fa-tachometer-alt me-1"></i>@Localizer["Organization Dashboard"]</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none" asp-area="" asp-controller="Organization" asp-action="Index"><i class="fas fa-building me-1"></i>@Localizer["Organizations"]</a></li>
                    </ul>
                </div>

                <!-- Column 4: Contact -->
                <div class="col-lg-3 col-md-6 mb-3">
                    <h6 class="fw-bold text-white mb-3">@Localizer["Contact"]</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2 text-white-50"><i class="fas fa-map-marker-alt me-2 text-primary"></i>Sofia, Bulgaria</li>
                        <li class="mb-2 text-white-50"><i class="fas fa-envelope me-2 text-primary"></i>support&#64;gocetransport.com</li>
                        <li class="mb-2 text-white-50"><i class="fas fa-phone me-2 text-primary"></i>+359 2 000 0000</li>
                    </ul>
                    <div class="mt-3">
                        <a asp-area="" asp-controller="Home" asp-action="AboutUs" class="btn btn-outline-light btn-sm rounded-pill px-3">
                            <i class="fas fa-info-circle me-1"></i>@Localizer["About Us"]
                        </a>
                    </div>
                </div>
            </div>

            <hr class="border-secondary my-4" />

            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 small text-white-50">&copy; @DateTime.Now.Year @GlobalConstants.SystemName. @Localizer["All rights reserved."]</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none small me-3">@Localizer["Privacy Policy"]</a>
                    <a asp-area="" asp-controller="Home" asp-action="Terms" class="text-white-50 text-decoration-none small">@Localizer["Terms of Service"]</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Mobile Bottom Navigation Bar (visible only on small screens) -->
    <nav class="d-flex d-lg-none fixed-bottom bg-body border-top shadow-sm" style="z-index:1050;">
        <a asp-controller="Home" asp-action="Index"
           class="flex-fill d-flex flex-column align-items-center justify-content-center py-2 text-decoration-none text-muted small fw-semibold"
           style="min-height:56px;">
            <i class="fas fa-search fs-5 mb-1"></i>
            <span>@Localizer["Search"]</span>
        </a>
        <a asp-controller="Schedule" asp-action="Index"
           class="flex-fill d-flex flex-column align-items-center justify-content-center py-2 text-decoration-none text-muted small fw-semibold"
           style="min-height:56px;">
            <i class="fas fa-calendar-alt fs-5 mb-1"></i>
            <span>@Localizer["Schedules"]</span>
        </a>
        @if (this.User.Identity.IsAuthenticated)
        {
            <a asp-controller="Ticket" asp-action="MyTickets"
               class="flex-fill d-flex flex-column align-items-center justify-content-center py-2 text-decoration-none text-muted small fw-semibold"
               style="min-height:56px;">
                <i class="fas fa-ticket-alt fs-5 mb-1"></i>
                <span>@Localizer["My Tickets"]</span>
            </a>
            <a asp-controller="Dashboard" asp-action="Index"
               class="flex-fill d-flex flex-column align-items-center justify-content-center py-2 text-decoration-none text-muted small fw-semibold"
               style="min-height:56px;">
                <i class="fas fa-tachometer-alt fs-5 mb-1"></i>
                <span>@Localizer["Dashboard"]</span>
            </a>
        }
        else
        {
            <a asp-controller="Organization" asp-action="Index"
               class="flex-fill d-flex flex-column align-items-center justify-content-center py-2 text-decoration-none text-muted small fw-semibold"
               style="min-height:56px;">
                <i class="fas fa-building fs-5 mb-1"></i>
                <span>@Localizer["Organizations"]</span>
            </a>
            <a asp-area="Identity" asp-page="/Account/Login"
               class="flex-fill d-flex flex-column align-items-center justify-content-center py-2 text-decoration-none text-muted small fw-semibold"
               style="min-height:56px;">
                <i class="fas fa-sign-in-alt fs-5 mb-1"></i>
                <span>@Localizer["Login"]</span>
            </a>
        }
    </nav>
    <!-- Bottom nav spacer on mobile -->
    <div class="d-block d-lg-none" style="height:64px;"></div>

    <!-- SignalR Toast Container -->
    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;"></div>

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.min.js" asp-append-version="true"></script>
    <script src="~/lib/signalr/dist/browser/signalr.min.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script src="~/js/darkMode.js" asp-append-version="true"></script>
    <script src="~/js/hoverDropdown.js" asp-append-version="true"></script>
    @await this.RenderSectionAsync("Scripts", required: false)
</body>
</html>
