@model GoceTransportApp.Web.ViewModels.Drivers.DriverInputModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Add Driver";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <i class="fas fa-user-tie fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Add New Driver"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Create" method="post" class="needs-validation" novalidate>
                    <input asp-for="OrganizationId" type="hidden" />

                    <div class="form-floating mb-3">
                        <input asp-for="FirstName" class="form-control rounded-3" placeholder="@Localizer["First Name"]" />
                        <label asp-for="FirstName">@Localizer["First Name"]</label>
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="LastName" class="form-control rounded-3" placeholder="@Localizer["Last Name"]" />
                        <label asp-for="LastName">@Localizer["Last Name"]</label>
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Age" class="form-control rounded-3" placeholder="@Localizer["Age"]" />
                        <label asp-for="Age">@Localizer["Age"]</label>
                        <span asp-validation-for="Age" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DrivingExperience" class="form-label text-muted">@Localizer["Driving Experience"]</label>
                        <select asp-for="DrivingExperience" asp-items="Html.GetEnumSelectList<GoceTransportApp.Data.Models.Enumerations.DriverExperience>()" class="form-select rounded-3"></select>
                        <span asp-validation-for="DrivingExperience" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>@Localizer["Save"]
                    </button>
                    <a asp-controller="Organization" asp-action="Details" asp-route-id="@Model.OrganizationId" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-times me-2"></i>@Localizer["Cancel"]
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
