@using System.Security.Claims
@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Organizations.OrganizationDetailsViewModel
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Model.Name;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwnerOrAdmin = currentUserId == Model.FounderId || User.IsInRole("Administrator");
}

<!-- Organization Dashboard Metrics (Owner/Admin only) -->
@if (isOwnerOrAdmin)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="fas fa-route text-primary fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4">@Model.OrganizationRoutes.Count</div>
                        <div class="text-muted small fw-semibold">@Localizer["Active Routes"]</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="fas fa-bus text-info fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4">@Model.OrganizationVehicles.Count</div>
                        <div class="text-muted small fw-semibold">@Localizer["Vehicles"]</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="fas fa-id-card text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4">@Model.OrganizationDrivers.Count</div>
                        <div class="text-muted small fw-semibold">@Localizer["Drivers"]</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="fas fa-ticket-alt text-warning fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4">@Model.OrganizationTickets.Count</div>
                        <div class="text-muted small fw-semibold">@Localizer["Tickets"]</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4 mt-2">

    @* Left column: profile card *@
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 text-center">
            <div class="card-body pt-4 pb-4">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name"
                         class="rounded-circle border shadow-sm mb-3"
                         style="width:120px;height:120px;object-fit:cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold mx-auto mb-3"
                         style="width:120px;height:120px;font-size:2.5rem;">
                        @Model.Name.Substring(0, 1).ToUpper()
                    </div>
                }

                <h4 class="fw-bold mb-1">@Model.Name</h4>

                @if (!string.IsNullOrEmpty(Model.Address))
                {
                    <p class="text-muted small mb-1">
                        <i class="fas fa-map-marker-alt me-1 text-primary"></i>@Model.Address
                    </p>
                }
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <p class="text-muted small mb-1">
                        <i class="fas fa-phone me-1 text-primary"></i>@Model.Phone
                    </p>
                }
                <p class="text-muted small mb-0">
                    <i class="fas fa-user me-1 text-primary"></i>@Model.Founder
                </p>

                @* Star rating display *@
                <div class="mt-3">
                    @{
                        int fullStars = (int)Math.Floor(Model.AverageRating);
                        bool halfStar = (Model.AverageRating - fullStars) >= 0.5;
                        int emptyStars = 5 - fullStars - (halfStar ? 1 : 0);
                    }
                    @for (int s = 0; s < fullStars; s++)
                    {
                        <i class="bi bi-star-fill text-warning fs-5"></i>
                    }
                    @if (halfStar)
                    {
                        <i class="bi bi-star-half text-warning fs-5"></i>
                    }
                    @for (int s = 0; s < emptyStars; s++)
                    {
                        <i class="bi bi-star text-warning fs-5"></i>
                    }
                    @if (Model.AverageRating > 0)
                    {
                        <span class="ms-1 fw-semibold text-dark">@Model.AverageRating.ToString("0.0")</span>
                        <span class="text-muted small">/ 5 (@Model.Reviews.Count() @Localizer["reviews"])</span>
                    }
                    else
                    {
                        <span class="text-muted small ms-1">@Localizer["No ratings yet"]</span>
                    }
                </div>
            </div>

            @if (isOwnerOrAdmin)
            {
                <div class="card-footer bg-white border-0 pb-4 d-flex gap-2 justify-content-center">
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                        <i class="fas fa-edit me-1"></i>@Localizer["Edit"]
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-danger rounded-pill px-3">
                        <i class="fas fa-trash-alt me-1"></i>@Localizer["Delete"]
                    </a>
                </div>
            }
        </div>

        @if (User.Identity.IsAuthenticated && currentUserId != Model.FounderId)
        {
            <div class="card border-0 shadow-sm rounded-4 mt-3 text-center p-3">
                <form asp-action="ToggleFavorite" asp-controller="Organization" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    @if (Model.IsFavorite)
                    {
                        <button type="submit" class="btn btn-warning rounded-pill px-4">
                            <i class="fas fa-heart me-1"></i>@Localizer["Unfollow"]
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                            <i class="far fa-heart me-1"></i>@Localizer["Follow"]
                        </button>
                    }
                </form>
            </div>
        }

        <div class="mt-3 text-center">
            <a asp-action="Index" asp-controller="Organization" class="btn btn-link text-muted text-decoration-none">
                <i class="fas fa-arrow-left me-1"></i>@Localizer["Back to List"]
            </a>
        </div>
    </div>

    @* Right column: nav tabs *@
    <div class="col-lg-8">
        <ul class="nav nav-tabs mb-4" id="orgTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="routes-tab" data-bs-toggle="tab" data-bs-target="#routes" type="button" role="tab">
                    <i class="fas fa-route me-1"></i>@Localizer["Routes"]
                    <span class="badge bg-secondary ms-1">@Model.OrganizationRoutes.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="vehicles-tab" data-bs-toggle="tab" data-bs-target="#vehicles" type="button" role="tab">
                    <i class="fas fa-bus me-1"></i>@Localizer["Vehicles"]
                    <span class="badge bg-secondary ms-1">@Model.OrganizationVehicles.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="drivers-tab" data-bs-toggle="tab" data-bs-target="#drivers" type="button" role="tab">
                    <i class="fas fa-id-card me-1"></i>@Localizer["Drivers"]
                    <span class="badge bg-secondary ms-1">@Model.OrganizationDrivers.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="schedules-tab" data-bs-toggle="tab" data-bs-target="#schedules" type="button" role="tab">
                    <i class="fas fa-calendar-alt me-1"></i>@Localizer["Schedules"]
                    <span class="badge bg-secondary ms-1">@Model.OrganizationSchedules.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tickets-tab" data-bs-toggle="tab" data-bs-target="#tickets" type="button" role="tab">
                    <i class="fas fa-ticket-alt me-1"></i>@Localizer["Tickets"]
                    <span class="badge bg-secondary ms-1">@Model.OrganizationTickets.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">
                    <i class="bi bi-star me-1"></i>@Localizer["Reviews"]
                    <span class="badge bg-secondary ms-1">@Model.Reviews.Count()</span>
                </button>
            </li>
        </ul>

        <div class="tab-content" id="orgTabsContent">

            @* Routes tab *@
            <div class="tab-pane fade show active" id="routes" role="tabpanel">
                @if (isOwnerOrAdmin)
                {
                    <div class="mb-3">
                        <a asp-controller="Route" asp-action="Create" asp-route-organizationId="@Model.Id"
                           class="btn btn-sm btn-primary rounded-pill px-3">
                            <i class="fas fa-plus me-1"></i>@Localizer["Add Route"]
                        </a>
                    </div>
                }
                @if (Model.OrganizationRoutes.Any())
                {
                    @foreach (var route in Model.OrganizationRoutes)
                    {
                        <div class="card mb-3 shadow-sm border-0 rounded-3">
                            <div class="card-body d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="fas fa-route text-danger me-2"></i>
                                    <span class="fw-semibold">@Localizer["Route"]</span>
                                    @{
                                        int rDurMins = (int)route.Duration;
                                        string rDurFormatted = rDurMins >= 60
                                            ? $"{rDurMins / 60} h. {rDurMins % 60} min."
                                            : $"{rDurMins} min.";
                                    }
                                    <span class="text-muted small ms-2">@route.Distance km · @rDurFormatted</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <a asp-controller="Route" asp-action="Details" asp-route-id="@route.Id" asp-route-organizationId="@Model.Id"
                                       class="btn btn-sm btn-outline-secondary rounded-pill">@Localizer["Details"]</a>
                                    @if (isOwnerOrAdmin)
                                    {
                                        <a asp-controller="Route" asp-action="Edit" asp-route-id="@route.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fas fa-edit"></i></a>
                                        <a asp-controller="Route" asp-action="Delete" asp-route-id="@route.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-danger rounded-pill"><i class="fas fa-trash-alt"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 bg-body rounded-4 shadow-sm">
                        <i class="fas fa-route fa-3x text-muted mb-3"></i>
                        <h4 class="fw-semibold">@Localizer["No routes found"]</h4>
                        <p class="text-muted">@Localizer["No routes have been added for this organization yet."]</p>
                    </div>
                }
            </div>

            @* Vehicles tab *@
            <div class="tab-pane fade" id="vehicles" role="tabpanel">
                @if (isOwnerOrAdmin)
                {
                    <div class="mb-3">
                        <a asp-controller="Vehicle" asp-action="Create" asp-route-organizationId="@Model.Id"
                           class="btn btn-sm btn-primary rounded-pill px-3">
                            <i class="fas fa-plus me-1"></i>@Localizer["Add Vehicle"]
                        </a>
                    </div>
                }
                @if (Model.OrganizationVehicles.Any())
                {
                    @foreach (var vehicle in Model.OrganizationVehicles)
                    {
                        <div class="card mb-3 shadow-sm border-0 rounded-3">
                            <div class="card-body d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="fas fa-bus text-info me-2"></i>
                                    <span class="fw-semibold">@vehicle.Manufacturer @vehicle.Model</span>
                                    <span class="text-muted small ms-2">(@vehicle.Number)</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <a asp-controller="Vehicle" asp-action="Details" asp-route-id="@vehicle.Id" asp-route-organizationId="@Model.Id"
                                       class="btn btn-sm btn-outline-secondary rounded-pill">@Localizer["Details"]</a>
                                    @if (isOwnerOrAdmin)
                                    {
                                        <a asp-controller="Vehicle" asp-action="Edit" asp-route-id="@vehicle.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fas fa-edit"></i></a>
                                        <a asp-controller="Vehicle" asp-action="Delete" asp-route-id="@vehicle.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-danger rounded-pill"><i class="fas fa-trash-alt"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 bg-body rounded-4 shadow-sm">
                        <i class="fas fa-bus fa-3x text-muted mb-3"></i>
                        <h4 class="fw-semibold">@Localizer["No vehicles found"]</h4>
                        <p class="text-muted">@Localizer["No vehicles have been added for this organization yet."]</p>
                    </div>
                }
            </div>

            @* Drivers tab *@
            <div class="tab-pane fade" id="drivers" role="tabpanel">
                @if (isOwnerOrAdmin)
                {
                    <div class="mb-3">
                        <a asp-controller="Driver" asp-action="Create" asp-route-organizationId="@Model.Id"
                           class="btn btn-sm btn-primary rounded-pill px-3">
                            <i class="fas fa-plus me-1"></i>@Localizer["Add Driver"]
                        </a>
                    </div>
                }
                @if (Model.OrganizationDrivers.Any())
                {
                    @foreach (var driver in Model.OrganizationDrivers)
                    {
                        <div class="card mb-3 shadow-sm border-0 rounded-3">
                            <div class="card-body d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="fas fa-user-tie text-secondary me-2"></i>
                                    <span class="fw-semibold">@driver.FirstName @driver.LastName</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <a asp-controller="Driver" asp-action="Details" asp-route-id="@driver.Id" asp-route-organizationId="@Model.Id"
                                       class="btn btn-sm btn-outline-secondary rounded-pill">@Localizer["Details"]</a>
                                    @if (isOwnerOrAdmin)
                                    {
                                        <a asp-controller="Driver" asp-action="Edit" asp-route-id="@driver.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fas fa-edit"></i></a>
                                        <a asp-controller="Driver" asp-action="Delete" asp-route-id="@driver.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-danger rounded-pill"><i class="fas fa-trash-alt"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 bg-body rounded-4 shadow-sm">
                        <i class="fas fa-user-tie fa-3x text-muted mb-3"></i>
                        <h4 class="fw-semibold">@Localizer["No drivers found"]</h4>
                        <p class="text-muted">@Localizer["No drivers have been added for this organization yet."]</p>
                    </div>
                }
            </div>

            @* Schedules tab *@
            <div class="tab-pane fade" id="schedules" role="tabpanel">
                @if (isOwnerOrAdmin)
                {
                    <div class="mb-3">
                        <a asp-controller="Schedule" asp-action="Create" asp-route-organizationId="@Model.Id"
                           class="btn btn-sm btn-primary rounded-pill px-3">
                            <i class="fas fa-plus me-1"></i>@Localizer["Add Schedule"]
                        </a>
                    </div>
                }
                @if (Model.OrganizationSchedules.Any())
                {
                    @foreach (var schedule in Model.OrganizationSchedules)
                    {
                        <div class="card mb-3 shadow-sm border-0 rounded-3">
                            <div class="card-body d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="fas fa-clock text-warning me-2"></i>
                                    <span class="fw-semibold">@schedule.Departure.ToString("HH:mm")</span>
                                    <span class="text-muted small ms-2">→ @schedule.Arrival.ToString("HH:mm")</span>
                                    <span class="badge bg-light text-muted ms-2">@schedule.Day</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <a asp-controller="Schedule" asp-action="Details" asp-route-id="@schedule.Id" asp-route-organizationId="@Model.Id"
                                       class="btn btn-sm btn-outline-secondary rounded-pill">@Localizer["Details"]</a>
                                    @if (isOwnerOrAdmin)
                                    {
                                        <a asp-controller="Schedule" asp-action="Edit" asp-route-id="@schedule.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fas fa-edit"></i></a>
                                        <a asp-controller="Schedule" asp-action="Delete" asp-route-id="@schedule.Id" asp-route-organizationId="@Model.Id"
                                           class="btn btn-sm btn-outline-danger rounded-pill"><i class="fas fa-trash-alt"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 bg-body rounded-4 shadow-sm">
                        <i class="fas fa-calendar-alt fa-3x text-muted mb-3"></i>
                        <h4 class="fw-semibold">@Localizer["No schedules found"]</h4>
                        <p class="text-muted">@Localizer["No schedules have been added for this organization yet."]</p>
                    </div>
                }
            </div>

            @* Tickets tab *@
            <div class="tab-pane fade" id="tickets" role="tabpanel">
                @if (isOwnerOrAdmin)
                {
                    <div class="mb-3">
                        <a asp-controller="Ticket" asp-action="Create" asp-route-organizationId="@Model.Id"
                           class="btn btn-sm btn-primary rounded-pill px-3">
                            <i class="fas fa-plus me-1"></i>@Localizer["Add Ticket"]
                        </a>
                    </div>
                }
                @if (Model.OrganizationTickets.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle rounded-3 overflow-hidden">
                            <thead class="table-light">
                                <tr>
                                    <th>@Localizer["Route"]</th>
                                    <th>@Localizer["Issued"]</th>
                                    <th>@Localizer["Expires"]</th>
                                    <th>@Localizer["Price"]</th>
                                    @if (isOwnerOrAdmin)
                                    {
                                        <th></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.OrganizationTickets)
                                {
                                    string fromCity = ticket.Route?.FromCity?.Name ?? "—";
                                    string toCity = ticket.Route?.ToCity?.Name ?? "—";
                                    <tr>
                                        <td>
                                            <i class="fas fa-route text-primary me-1"></i>
                                            <span class="fw-semibold">@fromCity</span>
                                            <i class="fas fa-arrow-right text-muted mx-1 small"></i>
                                            <span class="fw-semibold">@toCity</span>
                                        </td>
                                        <td class="text-muted small">@ticket.IssuedDate.ToString("dd MMM yyyy")</td>
                                        <td class="text-muted small">@ticket.ExpiryDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge bg-success bg-opacity-10 text-success fw-semibold">@ticket.Price.ToString("F2") BGN</span>
                                        </td>
                                        <td class="text-end">
                                            @if (isOwnerOrAdmin)
                                            {
                                                <a asp-controller="Ticket" asp-action="Details" asp-route-id="@ticket.Id" asp-route-organizationId="@Model.Id"
                                                   class="btn btn-sm btn-outline-secondary rounded-pill">@Localizer["Details"]</a>
                                                <a asp-controller="Ticket" asp-action="Edit" asp-route-id="@ticket.Id" asp-route-organizationId="@Model.Id"
                                                   class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fas fa-edit"></i></a>
                                                <a asp-controller="Ticket" asp-action="Delete" asp-route-id="@ticket.Id" asp-route-organizationId="@Model.Id"
                                                   class="btn btn-sm btn-outline-danger rounded-pill"><i class="fas fa-trash-alt"></i></a>
                                            }
                                            @if (!isOwnerOrAdmin && User.Identity != null && User.Identity.IsAuthenticated)
                                            {
                                                <form asp-controller="Ticket" asp-action="Purchase" asp-route-id="@ticket.Id" asp-route-organizationId="@Model.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-success rounded-pill">
                                                        <i class="fas fa-shopping-cart me-1"></i>@Localizer["Buy"]
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 bg-body rounded-4 shadow-sm">
                        <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
                        <h4 class="fw-semibold">@Localizer["No tickets found"]</h4>
                        <p class="text-muted">@Localizer["No tickets have been issued for this organization yet."]</p>
                    </div>
                }
            </div>

            @* Reviews tab *@
            <div class="tab-pane fade" id="reviews" role="tabpanel">

                @* Add review form — only for logged-in users *@
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">@Localizer["Leave a Review"]</h6>
                            <form asp-action="AddReview" asp-controller="Organization" method="post">
                                <input type="hidden" name="organizationId" value="@Model.Id" />
                                <div class="mb-3">
                                    <label class="form-label">@Localizer["Rating"]</label>
                                    <select name="rating" class="form-select form-select-sm w-auto">
                                        <option value="5">&#9733;&#9733;&#9733;&#9733;&#9733; — @Localizer["Excellent"]</option>
                                        <option value="4">&#9733;&#9733;&#9733;&#9733;&#9734; — @Localizer["Good"]</option>
                                        <option value="3">&#9733;&#9733;&#9733;&#9734;&#9734; — @Localizer["Average"]</option>
                                        <option value="2">&#9733;&#9733;&#9734;&#9734;&#9734; — @Localizer["Poor"]</option>
                                        <option value="1">&#9733;&#9734;&#9734;&#9734;&#9734; — @Localizer["Terrible"]</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">@Localizer["Comment (optional)"]</label>
                                    <textarea name="comment" class="form-control" rows="2" maxlength="500" placeholder="@Localizer["Share your experience..."]"></textarea>
                                </div>
                                <button type="submit" class="btn btn-sm btn-primary rounded-pill px-4">
                                    <i class="bi bi-send me-1"></i>@Localizer["Submit Review"]
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @* Reviews list *@
                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="card mb-3 border-0 shadow-sm rounded-3">
                            <div class="card-body py-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-semibold">@review.PassengerName</span>
                                    <span class="text-muted small">@review.CreatedOn.ToString("dd MMM yyyy")</span>
                                </div>
                                <div class="mb-1">
                                    @for (int s = 0; s < review.Rating; s++)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    @for (int s = review.Rating; s < 5; s++)
                                    {
                                        <i class="bi bi-star text-warning"></i>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p class="mb-0 text-muted small">@review.Comment</p>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 bg-body rounded-4 shadow-sm">
                        <i class="bi bi-star fa-3x text-muted mb-3 fs-1"></i>
                        <h4 class="fw-semibold">@Localizer["No reviews yet"]</h4>
                        <p class="text-muted">@Localizer["Be the first to share your experience with this carrier."]</p>
                    </div>
                }
            </div>

        </div>
    </div>

</div>
