@model GoceTransportApp.Web.ViewModels.Schedules.TravelSearchViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@using GoceTransportApp.Data.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Резултати от търсенето";
    ViewData["MetaDescription"] = "Търси автобусни разписания между градове в България. Намери часове на тръгване, цени и налични билети.";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="fas fa-arrow-left me-1"></i> @Localizer["Back"]
    </a>
    <h2 class="fw-bold mb-0">@Localizer["Search Results"]</h2>
</div>

<!-- Compact search form -->
<div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
    <form asp-controller="Schedule" asp-action="Search" method="get">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-sm-4">
                <label class="form-label fw-semibold small mb-1">@Localizer["From"]</label>
                <select name="FromCityId" class="form-select rounded-3">
                    <option value="">— @Localizer["Select city"] —</option>
                    @foreach (var city in Model.Cities)
                    {
                        if (Model.FromCityId == city.Id.ToString())
                        {
                            <option value="@city.Id" selected>@city.Name</option>
                        }
                        else
                        {
                            <option value="@city.Id">@city.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-sm-4">
                <label class="form-label fw-semibold small mb-1">@Localizer["To"]</label>
                <select name="ToCityId" class="form-select rounded-3">
                    <option value="">— @Localizer["Select city"] —</option>
                    @foreach (var city in Model.Cities)
                    {
                        if (Model.ToCityId == city.Id.ToString())
                        {
                            <option value="@city.Id" selected>@city.Name</option>
                        }
                        else
                        {
                            <option value="@city.Id">@city.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-10 col-sm-3">
                <label class="form-label fw-semibold small mb-1">@Localizer["Date of Travel"]</label>
                <input type="date" name="DepartureDate" class="form-control rounded-3"
                       value="@(Model.DepartureDate.HasValue ? Model.DepartureDate.Value.ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-2 col-sm-1">
                <button type="submit" class="btn btn-primary w-100 rounded-3 py-2">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>
    </form>
</div>

@if (!string.IsNullOrEmpty(Model.FromCityId) && !string.IsNullOrEmpty(Model.ToCityId))
{
    @if (Model.Results.Any())
    {
        <p class="text-muted small mb-3">
            <i class="fas fa-bus me-1"></i>
            @Model.Results.Count() @Localizer["trips found"]
            @if (Model.DepartureDate.HasValue)
            {
                <span>@Localizer["for"] @Model.DepartureDate.Value.ToString("dddd, dd MMM yyyy")</span>
            }
        </p>

        <div class="d-flex flex-column gap-3">
            @foreach (var schedule in Model.Results)
            {
                <div class="card border-0 shadow-sm rounded-4 hover-elevate">
                    <div class="card-body p-3 p-md-4">
                        <div class="row align-items-center g-3">

                            <!-- Departure time — largest element -->
                            <div class="col-3 col-md-2 text-center">
                                <div class="fs-3 fw-bold text-primary lh-1">@schedule.Departing</div>
                                <div class="small text-muted">@Localizer["depart"]</div>
                            </div>

                            <!-- Arrow and duration -->
                            <div class="col-1 text-center d-none d-md-block">
                                <i class="fas fa-long-arrow-alt-right fa-2x text-muted"></i>
                            </div>

                            <!-- Arrival time -->
                            <div class="col-3 col-md-2 text-center">
                                <div class="fs-3 fw-bold text-secondary lh-1">@schedule.Arriving</div>
                                <div class="small text-muted">@Localizer["arrive"]</div>
                            </div>

                            <!-- Route and company info -->
                            <div class="col-12 col-md-4">
                                <div class="fs-5 fw-semibold">
                                    @schedule.FromCity
                                    <i class="fas fa-arrow-right text-muted mx-1 small"></i>
                                    @schedule.ToCity
                                </div>
                                <div class="small text-muted mt-1">
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill me-2">
                                        <i class="fas fa-calendar-day me-1"></i>@schedule.Day
                                    </span>
                                    @if (!string.IsNullOrEmpty(schedule.OrganizationName))
                                    {
                                        <span>
                                            <i class="fas fa-building me-1 text-primary"></i>@schedule.OrganizationName
                                        </span>
                                    }
                                </div>
                            </div>

                            <!-- Action buttons -->
                            <div class="col-12 col-md-3 d-flex gap-2 justify-content-md-end">
                                <a asp-controller="Schedule" asp-action="Details"
                                   asp-route-id="@schedule.Id"
                                   asp-route-organizationId="@schedule.OrganizationId"
                                   class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1 flex-md-grow-0 px-3">
                                    <i class="fas fa-info-circle me-1"></i>@Localizer["Details"]
                                </a>
                                @if (this.SignInManager.IsSignedIn(this.User))
                                {
                                    <a asp-controller="Organization" asp-action="Details"
                                       asp-route-id="@schedule.OrganizationId"
                                       class="btn btn-success btn-sm rounded-pill flex-grow-1 flex-md-grow-0 px-3">
                                        <i class="fas fa-ticket-alt me-1"></i>@Localizer["Tickets"]
                                    </a>
                                }
                                else
                                {
                                    <a asp-area="Identity" asp-page="/Account/Login"
                                       class="btn btn-outline-success btn-sm rounded-pill flex-grow-1 flex-md-grow-0 px-3">
                                        <i class="fas fa-sign-in-alt me-1"></i>@Localizer["Login to buy"]
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-bus fa-3x text-muted mb-3"></i>
            <h5>@Localizer["No schedules found for the selected criteria."]</h5>
            <p class="text-muted">@Localizer["Try changing the cities or selecting a different date."]</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4">
                <i class="fas fa-search me-1"></i>@Localizer["Search Again"]
            </a>
        </div>
    }
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-bus fa-3x text-muted mb-3"></i>
        <p class="text-muted fs-5">@Localizer["Select origin and destination cities to find available trips."]</p>
    </div>
}
