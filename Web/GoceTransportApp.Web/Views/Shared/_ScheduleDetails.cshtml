@using GoceTransportApp.Services.Data.Users
@using System.Security.Claims
@using static GoceTransportApp.Common.GlobalConstants
@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Schedules.ScheduleDetailsViewModel
@inject IUserService userService
@inject IViewLocalizer Localizer
@{
    var organizationId = Model.OrganizationId;
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isFounder = await userService.HasUserCreatedOrganizationAsync(userId, organizationId);
    var isAdmin = User.IsInRole(AdministratorRoleName);
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="fas fa-calendar-day fa-2x text-primary mb-2"></i>
                    <h5 class="card-title fw-semibold">@Model.Day</h5>
                </div>
                <p class="card-text">
                    <strong>@Localizer["Recurrence"]:</strong>
                    @{
                        var recurrenceLabel = Model.RecurrencePattern switch
                        {
                            "Daily"      => Localizer["Daily"].Value,
                            "Weekdays"   => Localizer["Weekdays (Mon–Fri)"].Value,
                            "Weekends"   => Localizer["Weekends (Sat–Sun)"].Value,
                            _            => $"{Localizer["Every"].Value} {Localizer[Model.Day].Value}",
                        };
                    }
                    @recurrenceLabel<br />
                    <strong>@Localizer["Departing"]:</strong> @Model.Departing<br />
                    <strong>@Localizer["Arriving"]:</strong> @Model.Arriving<br />
                    <strong>@Localizer["From"]:</strong> @Model.FromCity (@Model.FromStreet)<br />
                    <strong>@Localizer["To"]:</strong> @Model.ToCity (@Model.ToStreet)<br />
                    <strong>@Localizer["Vehicle"]:</strong> @Model.VehicleNumber<br />
                    <strong>@Localizer["Organization"]:</strong> @Model.OrganizationName
                </p>
                <div class="d-flex flex-column gap-2 mt-3">
                    @if (isFounder || isAdmin)
                    {
                        <a asp-action="Passengers" asp-controller="Schedule" asp-route-id="@Model.Id" asp-route-organizationId="@Model.OrganizationId" class="btn btn-primary rounded-pill w-100">
                            <i class="fas fa-users me-1"></i> @Localizer["Passenger List"]
                        </a>
                        <a asp-action="Edit" asp-controller="Schedule" asp-route-id="@Model.Id" asp-route-organizationId="@Model.OrganizationId" class="btn btn-outline-warning rounded-pill w-100">
                            <i class="fas fa-edit"></i> @Localizer["Edit"]
                        </a>
                        <a asp-action="Delete" asp-controller="Schedule" asp-route-id="@Model.Id" asp-route-organizationId="@Model.OrganizationId" class="btn btn-outline-danger rounded-pill w-100">
                            <i class="fas fa-trash-alt"></i> @Localizer["Delete"]
                        </a>
                    }
                    <a asp-action="Index" asp-controller="Schedule" class="btn btn-outline-secondary rounded-pill w-100">
                        <i class="fas fa-arrow-left"></i> @Localizer["Back to List"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
