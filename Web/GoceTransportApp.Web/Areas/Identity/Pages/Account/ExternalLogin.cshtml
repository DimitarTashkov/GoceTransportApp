@page
@model ExternalLoginModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = "Регистрация чрез външен акаунт";
}

<div class="row justify-content-center py-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="fas fa-user-plus fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@ViewData["Title"]</h1>
            <p class="text-muted">Влизате чрез <strong>@Model.ProviderDisplayName</strong>. Моля, въведете имейл адрес.</p>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>
                <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="email" placeholder="name@example.com" />
                        <label asp-for="Input.Email">Имейл</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-check me-2"></i>Регистрирай се
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
