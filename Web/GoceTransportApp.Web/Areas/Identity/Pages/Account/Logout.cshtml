@page
@model LogoutModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Log out"].Value;
}

<header>
    <h1>@ViewData["Title"]</h1>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="nav-link btn btn-link text-dark">
                <i class="fas fa-sign-out-alt"></i> @Localizer["Click here to Logout"]
            </button>
        </form>
    }
    else
    {
        <p><i class="fas fa-check-circle text-success me-2"></i>@Localizer["You have successfully logged out of the application."]</p>
    }
</header>
