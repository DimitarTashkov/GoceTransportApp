@model GoceTransportApp.Web.ViewModels.Organizations.EditOrganizationInputModel

@{
    ViewData["Title"] = "Edit Organization";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <i class="fas fa-edit fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">Edit Organization</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="FounderId" />
                    <input type="hidden" asp-for="ExistingImageUrl" />

                    <div class="form-floating mb-3">
                        <input asp-for="Name" class="form-control rounded-3" placeholder="Organization Name" />
                        <label asp-for="Name" class="form-label text-muted">Name</label>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Address" class="form-control rounded-3" placeholder="Address" />
                        <label asp-for="Address" class="form-label text-muted">Address</label>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Phone" class="form-control rounded-3" placeholder="Phone" />
                        <label asp-for="Phone" class="form-label text-muted">Phone</label>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Image" class="form-label text-muted">Organization Logo</label>
                        @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                        {
                            <div class="mb-2">
                                <img src="@Model.ExistingImageUrl" alt="Current Logo" class="img-thumbnail" style="max-height: 100px;" />
                                <small class="text-muted d-block">Current logo. Upload a new file to replace it.</small>
                            </div>
                        }
                        <input asp-for="Image" type="file" class="form-control form-control-lg" accept="image/*" />
                        <span asp-validation-for="Image" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
