@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Routes.RouteDetailsViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject IViewLocalizer Localizer

@{
    int durationTotalMins = (int)Model.Duration;
    int durationHours = durationTotalMins / 60;
    int durationMins = durationTotalMins % 60;
    string durationFormatted = durationHours > 0
        ? $"{durationHours} h. {durationMins} min."
        : $"{durationMins} min.";

    bool hasFromCoords = Model.FromLatitude.HasValue && Model.FromLongitude.HasValue;
    bool hasToCoords = Model.ToLatitude.HasValue && Model.ToLongitude.HasValue;
    bool hasAnyCoords = hasFromCoords || hasToCoords;

    var mapsApiKey = Configuration["GoogleMaps:ApiKey"];
    var fromLatJs = hasFromCoords ? Model.FromLatitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null";
    var fromLngJs = hasFromCoords ? Model.FromLongitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null";
    var toLatJs = hasToCoords ? Model.ToLatitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null";
    var toLngJs = hasToCoords ? Model.ToLongitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="mb-3">
            <i class="fas fa-route fa-2x text-primary mb-2"></i>
            <h5 class="card-title fw-semibold">@Model.DepartingCity → @Model.ArrivingCity</h5>
        </div>
        <p class="card-text">
            <strong>@Localizer["Departing Street"]:</strong> @Model.DepartingStreet<br />
            <strong>@Localizer["Arriving Street"]:</strong> @Model.ArrivingStreet<br />
            <strong>@Localizer["Organization"]:</strong> @Model.Organization<br />
            <strong>@Localizer["Distance"]:</strong> @Model.Distance km<br />
            <strong>@Localizer["Duration"]:</strong> @durationFormatted
        </p>

        @if (hasFromCoords || hasToCoords)
        {
            <hr class="my-3" />
            <div class="d-flex flex-wrap gap-2 align-items-center">
                @if (hasFromCoords)
                {
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-success-subtle text-success border border-success rounded-pill px-3 py-2">
                            <i class="fas fa-map-pin me-1"></i>
                            @(string.IsNullOrWhiteSpace(Model.FromStopName) ? Localizer["Departure stop"].Value : Model.FromStopName)
                        </span>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.FromLatitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.FromLongitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                           target="_blank" rel="noopener"
                           class="btn btn-success btn-sm rounded-pill">
                            <i class="fas fa-directions me-1"></i>@Localizer["Navigate here"]
                        </a>
                    </div>
                }
                @if (hasToCoords)
                {
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-danger-subtle text-danger border border-danger rounded-pill px-3 py-2">
                            <i class="fas fa-map-pin me-1"></i>
                            @(string.IsNullOrWhiteSpace(Model.ToStopName) ? Localizer["Arrival stop"].Value : Model.ToStopName)
                        </span>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.ToLatitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.ToLongitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                           target="_blank" rel="noopener"
                           class="btn btn-danger btn-sm rounded-pill">
                            <i class="fas fa-directions me-1"></i>@Localizer["Navigate here"]
                        </a>
                    </div>
                }
                @if (hasAnyCoords)
                {
                    <button type="button" class="btn btn-outline-primary btn-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#routeMapModal">
                        <i class="fas fa-map me-1"></i>@Localizer["View on map"]
                    </button>
                }
            </div>
        }
    </div>
</div>

@if (hasAnyCoords)
{
    <!-- Route Map Modal -->
    <div class="modal fade" id="routeMapModal" tabindex="-1" aria-labelledby="routeMapModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-semibold" id="routeMapModalLabel">
                        <i class="fas fa-map-marked-alt text-primary me-2"></i>
                        @Model.DepartingCity → @Model.ArrivingCity
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-3">
                    @if (hasFromCoords && hasToCoords)
                    {
                        <ul class="nav nav-pills mb-3" id="mapModalTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="modal-from-tab" data-bs-toggle="pill" data-bs-target="#modal-from-pane" type="button" role="tab">
                                    <i class="fas fa-map-pin text-success me-1"></i>
                                    @(string.IsNullOrWhiteSpace(Model.FromStopName) ? Localizer["Departure"].Value : Model.FromStopName)
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="modal-to-tab" data-bs-toggle="pill" data-bs-target="#modal-to-pane" type="button" role="tab">
                                    <i class="fas fa-map-pin text-danger me-1"></i>
                                    @(string.IsNullOrWhiteSpace(Model.ToStopName) ? Localizer["Arrival"].Value : Model.ToStopName)
                                </button>
                            </li>
                        </ul>
                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="modal-from-pane" role="tabpanel">
                                <div id="modalFromMap" class="rounded-3" style="height: 380px;"></div>
                                <div class="mt-2 d-flex justify-content-end">
                                    <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.FromLatitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.FromLongitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       target="_blank" rel="noopener" class="btn btn-success rounded-pill">
                                        <i class="fas fa-directions me-2"></i>@Localizer["Navigate to stop (departure)"]
                                    </a>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="modal-to-pane" role="tabpanel">
                                <div id="modalToMap" class="rounded-3" style="height: 380px;"></div>
                                <div class="mt-2 d-flex justify-content-end">
                                    <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.ToLatitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.ToLongitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       target="_blank" rel="noopener" class="btn btn-danger rounded-pill">
                                        <i class="fas fa-directions me-2"></i>@Localizer["Navigate to stop (arrival)"]
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                    else if (hasFromCoords)
                    {
                        <div id="modalFromMap" class="rounded-3" style="height: 380px;"></div>
                        <div class="mt-2 d-flex justify-content-end">
                            <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.FromLatitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.FromLongitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               target="_blank" rel="noopener" class="btn btn-success rounded-pill">
                                <i class="fas fa-directions me-2"></i>@Localizer["Navigate to stop"]
                            </a>
                        </div>
                    }
                    else
                    {
                        <div id="modalToMap" class="rounded-3" style="height: 380px;"></div>
                        <div class="mt-2 d-flex justify-content-end">
                            <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.ToLatitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.ToLongitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               target="_blank" rel="noopener" class="btn btn-danger rounded-pill">
                                <i class="fas fa-directions me-2"></i>@Localizer["Navigate to stop"]
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div id="routeDetailMapData"
         data-from-lat="@fromLatJs"
         data-from-lng="@fromLngJs"
         data-to-lat="@toLatJs"
         data-to-lng="@toLngJs"
         data-from-stop="@(Model.FromStopName ?? "")"
         data-to-stop="@(Model.ToStopName ?? "")"
         data-departure-label="@Localizer["Departure stop"]"
         data-arrival-label="@Localizer["Arrival stop"]"
         style="display:none;"></div>
    <script src="~/js/routeDetailMap.js" asp-append-version="true"></script>
    <script async defer
        src="https://maps.googleapis.com/maps/api/js?key=@mapsApiKey">
    </script>
}
