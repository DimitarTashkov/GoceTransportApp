@using GoceTransportApp.Services.Data.Cities
@model GoceTransportApp.Web.ViewModels.Routes.RouteInputModel
@inject ICityService cityService
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Create Route";
    var cities = await cityService.GetAllCitiesForDropDownsAsync();
    var mapsApiKey = Configuration["GoogleMaps:ApiKey"];
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="text-center mb-4">
            <i class="fas fa-route fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Create New Route"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Create" method="post" class="needs-validation" novalidate>
                    <input asp-for="OrganizationId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="FromCityId" class="form-label text-muted">@Localizer["From City"]</label>
                        <select id="fromCity" asp-for="FromCityId" asp-items="@(new SelectList(cities, "Id", "Name"))" class="form-select rounded-3" onchange="loadStreets('fromCity', 'fromStreet')">
                            <option value="">@Localizer["Select a city"]</option>
                        </select>
                        <span asp-validation-for="FromCityId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FromStreetId" class="form-label text-muted">@Localizer["From Street"]</label>
                        <select id="fromStreet" asp-for="FromStreetId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a street"]</option>
                        </select>
                        <span asp-validation-for="FromStreetId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ToCityId" class="form-label text-muted">@Localizer["To City"]</label>
                        <select id="toCity" asp-for="ToCityId" asp-items="@(new SelectList(cities, "Id", "Name"))" class="form-select rounded-3" onchange="loadStreets('toCity', 'toStreet')">
                            <option value="">@Localizer["Select a city"]</option>
                        </select>
                        <span asp-validation-for="ToCityId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ToStreetId" class="form-label text-muted">@Localizer["To Street"]</label>
                        <select id="toStreet" asp-for="ToStreetId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a street"]</option>
                        </select>
                        <span asp-validation-for="ToStreetId" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Distance" class="form-control rounded-3" placeholder="@Localizer["Distance (km)"]" />
                        <label asp-for="Distance">@Localizer["Distance (km)"]</label>
                        <span asp-validation-for="Distance" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Duration" type="number" min="1" class="form-control rounded-3" placeholder="@Localizer["Duration (minutes) — e.g. 135"]" />
                        <label asp-for="Duration">@Localizer["Duration (minutes) — e.g. 135"]</label>
                        <span asp-validation-for="Duration" class="text-danger small"></span>
                    </div>

                    <!-- Stop Location Section -->
                    <hr class="my-4" />
                    <h5 class="fw-semibold mb-3">
                        <i class="fas fa-map-marker-alt text-danger me-2"></i>@Localizer["Stop Locations"]
                        <span class="badge bg-secondary fw-normal fs-6 ms-2">@Localizer["optional"]</span>
                    </h5>

                    @if (User.IsInRole("Administrator") || (bool)(ViewBag.IsPremiumUser ?? false))
                    {
                        <p class="text-muted small mb-3">@Localizer["Click on the map to place stop markers. This lets passengers navigate to the stop."]</p>

                        <!-- Nav tabs -->
                        <ul class="nav nav-pills mb-3" id="stopTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="from-tab" data-bs-toggle="pill" data-bs-target="#from-stop" type="button" role="tab">
                                    <i class="fas fa-map-pin me-1 text-success"></i>@Localizer["Departure"]
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="to-tab" data-bs-toggle="pill" data-bs-target="#to-stop" type="button" role="tab">
                                    <i class="fas fa-map-pin me-1 text-danger"></i>@Localizer["Arrival"]
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <!-- FROM STOP -->
                            <div class="tab-pane fade show active" id="from-stop" role="tabpanel">
                                <div class="mb-3">
                                    <label asp-for="FromStopName" class="form-label text-muted">@Localizer["Stop name (departure)"]</label>
                                    <input asp-for="FromStopName" class="form-control rounded-3" placeholder="@Localizer["e.g. South Bus Station — sector 5"]" />
                                </div>
                                <div id="fromMap" class="rounded-3 border mb-2" style="height: 280px;"></div>
                                <div class="d-flex gap-2 mb-2">
                                    <div class="flex-fill">
                                        <label class="form-label text-muted small">Latitude</label>
                                        <input asp-for="FromLatitude" id="fromLat" class="form-control form-control-sm rounded-3" placeholder="—" readonly />
                                    </div>
                                    <div class="flex-fill">
                                        <label class="form-label text-muted small">Longitude</label>
                                        <input asp-for="FromLongitude" id="fromLng" class="form-control form-control-sm rounded-3" placeholder="—" readonly />
                                    </div>
                                    <div class="d-flex align-items-end">
                                        <button type="button" class="btn btn-outline-secondary btn-sm rounded-3" onclick="clearFromMarker()">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <p class="text-muted small"><i class="fas fa-info-circle me-1"></i>@Localizer["Click on the map to place the marker."]</p>
                            </div>

                            <!-- TO STOP -->
                            <div class="tab-pane fade" id="to-stop" role="tabpanel">
                                <div class="mb-3">
                                    <label asp-for="ToStopName" class="form-label text-muted">@Localizer["Stop name (arrival)"]</label>
                                    <input asp-for="ToStopName" class="form-control rounded-3" placeholder="@Localizer["e.g. Central Bus Terminal — platform 3"]" />
                                </div>
                                <div id="toMap" class="rounded-3 border mb-2" style="height: 280px;"></div>
                                <div class="d-flex gap-2 mb-2">
                                    <div class="flex-fill">
                                        <label class="form-label text-muted small">Latitude</label>
                                        <input asp-for="ToLatitude" id="toLat" class="form-control form-control-sm rounded-3" placeholder="—" readonly />
                                    </div>
                                    <div class="flex-fill">
                                        <label class="form-label text-muted small">Longitude</label>
                                        <input asp-for="ToLongitude" id="toLng" class="form-control form-control-sm rounded-3" placeholder="—" readonly />
                                    </div>
                                    <div class="d-flex align-items-end">
                                        <button type="button" class="btn btn-outline-secondary btn-sm rounded-3" onclick="clearToMarker()">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <p class="text-muted small"><i class="fas fa-info-circle me-1"></i>@Localizer["Click on the map to place the marker."]</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
                            <i class="bi bi-lock-fill fs-5"></i>
                            <div>
                                @Localizer["Google Maps stop coordinates are available for Pro and Enterprise plans."]
                                <a asp-controller="Organization" asp-action="Upgrade" class="alert-link ms-1">@Localizer["View plans"]</a>
                            </div>
                        </div>
                    }

                    <hr class="my-4" />

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>@Localizer["Save"]
                    </button>
                    <a asp-controller="Organization" asp-action="Details" asp-route-id="@Model.OrganizationId" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-times me-2"></i>@Localizer["Cancel"]
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/loadStreetsInCity.js"></script>
    @if (User.IsInRole("Administrator") || (bool)(ViewBag.IsPremiumUser ?? false))
    {
        <div id="routeMapData"
             data-departure-label="@Localizer["Departure stop"]"
             data-arrival-label="@Localizer["Arrival stop"]"
             style="display:none;"></div>
        <script src="~/js/routeMap.js" asp-append-version="true"></script>
        <script async defer
            src="https://maps.googleapis.com/maps/api/js?key=@mapsApiKey&callback=initMaps">
        </script>
    }
}
