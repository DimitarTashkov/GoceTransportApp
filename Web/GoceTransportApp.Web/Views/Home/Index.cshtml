<!-- ══════════════════════════════════════════════
     INFO CARDS — About + Contact
     ══════════════════════════════════════════════ -->
<div class="row g-4 mt-2 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 p-4 hover-elevate">
            <div class="card-body text-center">
                <i class="fas fa-info-circle fa-2x text-primary mb-3"></i>
                <h5 class="fw-bold mb-2">@Localizer["About Us"]</h5>
