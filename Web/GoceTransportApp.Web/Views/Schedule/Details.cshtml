@model GoceTransportApp.Web.ViewModels.Schedules.ScheduleDetailsViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Schedule Details";
}

<div data-schedule-id="@Model.Id" id="scheduleDetailsWrapper">
    <h1 class="h2 fw-bold text-dark text-center mt-4 mb-4">@Localizer["Schedule Details"]</h1>

    @if (!string.IsNullOrEmpty(Model.LiveStatus))
    {
        <div id="liveStatusBanner" class="alert alert-danger d-flex align-items-center gap-2 rounded-3 fw-semibold mb-3" role="alert">
            <i class="fas fa-circle-exclamation fa-lg"></i>
            <span>@Model.LiveStatus</span>
        </div>
    }

    <partial name="_ScheduleDetails" model="Model" />
</div>

