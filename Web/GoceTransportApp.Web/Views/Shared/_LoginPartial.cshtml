@using GoceTransportApp.Common
@using GoceTransportApp.Data.Models
@using GoceTransportApp.Services.Data.Organizations
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Localization
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IOrganizationService OrganizationService
@inject IViewLocalizer Localizer

@if (this.SignInManager.IsSignedIn(this.User))
{
    var userId = UserManager.GetUserId(this.User);
    var isAdmin = this.User.IsInRole(GlobalConstants.AdministratorRoleName);
    var isOwner = isAdmin || await OrganizationService.UserHasOrganizationsAsync(userId);

    @if (isOwner)
    {
        <!-- Owner / Admin quick nav links -->
        <ul class="navbar-nav d-none d-lg-flex flex-row gap-1 me-2">
            <li class="nav-item">
                <a class="nav-link fw-semibold" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <i class="fas fa-tachometer-alt me-1 text-primary"></i>@Localizer["Dashboard"]
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold" asp-area="" asp-controller="Organization" asp-action="UserOrganizations">
                    <i class="fas fa-building me-1 text-primary"></i>@Localizer["My Organizations"]
                </a>
            </li>
        </ul>
    }
    else
    {
        <!-- Passenger quick nav links -->
        <ul class="navbar-nav d-none d-lg-flex flex-row gap-1 me-2">
            <li class="nav-item">
                <a class="nav-link fw-semibold" asp-area="" asp-controller="Ticket" asp-action="MyTickets">
                    <i class="fas fa-ticket-alt me-1 text-primary"></i>@Localizer["My Tickets"]
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold" asp-area="" asp-controller="Organization" asp-action="Favorites">
                    <i class="fas fa-heart me-1 text-danger"></i>@Localizer["Favorites"]
                </a>
            </li>
        </ul>
    }

    <ul class="navbar-nav">
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 fw-semibold" href="#" id="userProfileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle fw-bold" style="width:32px;height:32px;font-size:0.8rem;">
                    @{
                        var displayName = this.User.Identity?.Name ?? "U";
                        var initial = displayName.Substring(0, 1).ToUpper();
                    }
                    @initial
                </span>
                <span class="d-none d-lg-inline">@Localizer["My Account"]</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 py-2" style="min-width: 220px;">
                <li class="px-3 py-2 border-bottom">
                    <div class="fw-semibold small text-truncate">@this.User.Identity?.Name</div>
                </li>
                @if (isOwner)
                {
                    <li>
                        <a class="dropdown-item py-2" asp-area="" asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-tachometer-alt me-2 text-primary"></i>@Localizer["Dashboard"]
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" asp-area="" asp-controller="Organization" asp-action="UserOrganizations">
                            <i class="fas fa-building me-2 text-primary"></i>@Localizer["My Organizations"]
                        </a>
                    </li>
                }
                else
                {
                    <li>
                        <a class="dropdown-item py-2" asp-area="" asp-controller="Ticket" asp-action="MyTickets">
                            <i class="fas fa-ticket-alt me-2 text-primary"></i>@Localizer["My Tickets"]
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" asp-area="" asp-controller="Organization" asp-action="Favorites">
                            <i class="fas fa-heart me-2 text-danger"></i>@Localizer["Favorites"]
                        </a>
                    </li>
                }
                <li><hr class="dropdown-divider my-1" /></li>
                <li>
                    <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="fas fa-cog me-2 text-secondary"></i>@Localizer["Account Settings"]
                    </a>
                </li>
                @if (isAdmin)
                {
                    <li><hr class="dropdown-divider my-1" /></li>
                    <li class="px-3 pt-1 pb-1">
                        <span class="text-muted small fw-semibold text-uppercase">@Localizer["Admin"]</span>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" asp-area="Administration" asp-controller="UserAdministration" asp-action="Index">
                            <i class="fas fa-users-cog me-2 text-warning"></i>@Localizer["Manage Users"]
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" asp-area="" asp-controller="ContactForm" asp-action="Index">
                            <i class="fas fa-envelope-open-text me-2 text-warning"></i>@Localizer["Manage forms"]
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" asp-area="Administration" asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-chart-line me-2 text-warning"></i>@Localizer["Admin Dashboard"]
                        </a>
                    </li>
                }
                <li><hr class="dropdown-divider my-1" /></li>
                <li>
                    <form class="px-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@this.Url.Action("Index", "Home", new { area = string.Empty })">
                        <button type="submit" class="dropdown-item py-2 text-danger">
                            <i class="fas fa-sign-out-alt me-2"></i>@Localizer["Logout"]
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav d-flex flex-row gap-2 ms-2">
        <li class="nav-item">
            <a class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-semibold" asp-area="Identity" asp-page="/Account/Login">
                @Localizer["Login"]
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary btn-sm rounded-pill px-3 fw-semibold" asp-area="Identity" asp-page="/Account/Register">
                @Localizer["Register"]
            </a>
        </li>
    </ul>
}
