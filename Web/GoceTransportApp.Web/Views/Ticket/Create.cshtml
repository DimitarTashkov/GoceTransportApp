@model GoceTransportApp.Web.ViewModels.Tickets.TicketInputModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Create Ticket";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <i class="fas fa-ticket-alt fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Create Ticket"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Create" method="post">
                    <input asp-for="OrganizationId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="IssuedDate" class="form-label text-muted">@Localizer["Issued Date"]</label>
                        <input asp-for="IssuedDate" type="date" class="form-control rounded-3" />
                        <span asp-validation-for="IssuedDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ExpiryDate" class="form-label text-muted">@Localizer["Expiry Date"]</label>
                        <input asp-for="ExpiryDate" type="date" class="form-control rounded-3" />
                        <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Price" class="form-control rounded-3" placeholder="Price" />
                        <label asp-for="Price">@Localizer["Price ($)"]</label>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RouteId" class="form-label text-muted">@Localizer["Route"]</label>
                        <select asp-for="RouteId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a route"]</option>
                            @foreach (var route in Model.Routes)
                            {
                                <option value="@route.Value">@route.Text</option>
                            }
                        </select>
                        <span asp-validation-for="RouteId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ScheduleId" class="form-label text-muted">@Localizer["Schedule"]</label>
                        <select asp-for="ScheduleId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a schedule"]</option>
                            @foreach (var schedule in Model.Schedules)
                            {
                                <option value="@schedule.Value">@schedule.Text</option>
                            }
                        </select>
                        <span asp-validation-for="ScheduleId" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>@Localizer["Save"]
                    </button>
                    <a asp-controller="Organization" asp-action="Details" asp-route-id="@Model.OrganizationId" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-times me-2"></i>@Localizer["Cancel"]
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
