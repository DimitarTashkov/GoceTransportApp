@model GoceTransportApp.Web.ViewModels.Vehicles.EditVehicleInputModel

@{
    ViewData["Title"] = "Edit Vehicle";
    var returnUrl = Context.Request.Headers["Referer"].ToString();
    if (string.IsNullOrEmpty(returnUrl)) returnUrl = Url.Action("Index", "Route");
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <i class="fas fa-bus fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">Edit Vehicle</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                    <input type="hidden" asp-for="Id" />
                    <input asp-for="OrganizationId" type="hidden" />

                    <div class="form-floating mb-3">
                        <input asp-for="Number" class="form-control rounded-3" placeholder="Number" />
                        <label asp-for="Number">Number</label>
                        <span asp-validation-for="Number" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Type" class="form-control rounded-3" placeholder="Type" />
                        <label asp-for="Type">Type</label>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Manufacturer" class="form-control rounded-3" placeholder="Manufacturer" />
                        <label asp-for="Manufacturer">Manufacturer</label>
                        <span asp-validation-for="Manufacturer" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Model" class="form-control rounded-3" placeholder="Model" />
                        <label asp-for="Model">Model</label>
                        <span asp-validation-for="Model" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Capacity" class="form-control rounded-3" placeholder="Capacity" />
                        <label asp-for="Capacity">Capacity</label>
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="FuelConsumption" class="form-control rounded-3" placeholder="Fuel Consumption" />
                        <label asp-for="FuelConsumption">Fuel Consumption (L/100km)</label>
                        <span asp-validation-for="FuelConsumption" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-semibold">Status</label>
                        <select asp-for="Status" class="form-select rounded-3" asp-items="Html.GetEnumSelectList<GoceTransportApp.Data.Models.Enumerations.VehicleStatus>()">
                            <option value="">Select Status</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>Update
                    </button>
                    <a href="@returnUrl" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
