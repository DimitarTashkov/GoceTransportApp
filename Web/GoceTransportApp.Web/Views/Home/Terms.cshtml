@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    this.ViewData["Title"] = "Terms of Service";
    ViewData["MetaDescription"] = "GoceTrans Terms of Service — how the platform works and what we expect from everyone using it.";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="mb-4">
            <h1 class="fw-bold">@Localizer["Terms of Service"]</h1>
            <p class="text-muted small">@Localizer["Last updated: January 1, 2025"]</p>
        </div>

        <div class="alert alert-info mb-4">
            <i class="fas fa-info-circle me-2"></i>
            @Localizer["By using GoceTrans you agree to these terms. They're written to be straightforward — please take a moment to read them."]
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["1. What GoceTrans Is"]</h2>
                <p>@Localizer["GoceTrans is an online platform where passengers can find bus routes, check schedules, and manage tickets. We connect passengers with transport operators — we are not a transport operator ourselves and we don't run any buses."]</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["2. Your Account"]</h2>
                <ul>
                    <li>@Localizer["Keep your login details safe — you're responsible for anything done through your account."]</li>
                    <li>@Localizer["Accounts are personal and cannot be shared or transferred."]</li>
                    <li>@Localizer["Providing false information when registering may result in your account being suspended."]</li>
                    <li>@Localizer["After 5 failed login attempts your account will be temporarily locked for 15 minutes."]</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["3. Buying Tickets"]</h2>
                <ul>
                    <li>@Localizer["Each ticket is for a specific route and schedule."]</li>
                    <li>@Localizer["Prices are set by the transport organization — GoceTrans doesn't set them."]</li>
                    <li>@Localizer["You can't buy tickets for schedules that have already passed."]</li>
                    <li>@Localizer["Tickets are tied to your account and cannot be transferred to another person."]</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["4. Cancellations and Refunds"]</h2>
                <ul>
                    <li>@Localizer["Refunds are handled by the transport operator — contact them directly for refund requests."]</li>
                    <li>@Localizer["GoceTrans does not process payments and does not issue refunds."]</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["5. Transport Organizations"]</h2>
                <p>@Localizer["If you register a transport organization on GoceTrans:"]</p>
                <ul>
                    <li>@Localizer["You confirm you are authorized to operate the listed services."]</li>
                    <li>@Localizer["You're responsible for keeping your routes, schedules, prices, and vehicle capacity accurate."]</li>
                    <li>@Localizer["Organizations that repeatedly violate these terms may be removed from the platform."]</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["6. What You Must Not Do"]</h2>
                <p>@Localizer["To keep the platform fair and safe for everyone, please don't:"]</p>
                <ul>
                    <li>@Localizer["Use the platform for anything illegal."]</li>
                    <li>@Localizer["Create fake organizations, routes, schedules, or reviews."]</li>
                    <li>@Localizer["Try to access someone else's account or data."]</li>
                    <li>@Localizer["Use bots or automated tools to scrape data or buy tickets in bulk."]</li>
                    <li>@Localizer["Try to bypass security measures or rate limits."]</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["7. Our Responsibility"]</h2>
                <p>@Localizer["GoceTrans is a booking platform, not a transport provider. We are not responsible for:"]</p>
                <ul>
                    <li>@Localizer["Delays, cancellations, or changes made by transport operators."]</li>
                    <li>@Localizer["Any loss or damage that occurs during travel."]</li>
                    <li>@Localizer["Errors in schedule or route information entered by operators."]</li>
                    <li>@Localizer["Temporary service interruptions due to maintenance or technical issues."]</li>
                </ul>
            </div>
        </div>


        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">@Localizer["8. Changes to These Terms"]</h2>
                <p>@Localizer["We may update these terms occasionally. If you continue using GoceTrans after a change, that counts as acceptance. We'll always update the date at the top so you know when something changed."]</p>
            </div>
        </div>

        <p class="text-muted small">
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">@Localizer["Privacy Policy"]</a> |
            <a asp-controller="ContactForm" asp-action="Create" class="text-decoration-none">@Localizer["Contact Us"]</a>
        </p>
    </div>
</div>
