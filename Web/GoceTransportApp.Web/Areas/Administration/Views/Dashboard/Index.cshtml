@model GoceTransportApp.Web.ViewModels.Administration.Dashboard.IndexViewModel
@{
    this.ViewData["Title"] = "Admin Dashboard";
}

<div class="text-center mb-5">
    <i class="fas fa-tachometer-alt fa-3x text-primary mb-3"></i>
    <h1 class="h2 fw-bold">Admin Dashboard</h1>
    <p class="text-muted">Manage all entities in the system.</p>
</div>

<div class="row g-4">
    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Organization" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-building fa-3x text-primary mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Organizations</h5>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Ticket" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-ticket-alt fa-3x text-success mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Tickets</h5>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Route" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-route fa-3x text-danger mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Routes</h5>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Schedule" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-calendar-alt fa-3x text-warning mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Schedules</h5>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Vehicle" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-bus fa-3x text-info mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Vehicles</h5>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Driver" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-user-tie fa-3x text-secondary mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Drivers</h5>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="City" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-city fa-3x text-dark mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Cities</h5>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Street" asp-area="" asp-action="Index" class="card text-center border-0 shadow-sm rounded-4 text-decoration-none h-100">
            <div class="card-body p-4">
                <i class="fas fa-road fa-3x text-muted mb-3"></i>
                <h5 class="card-title fw-semibold">Manage Streets</h5>
            </div>
        </a>
    </div>
</div>
