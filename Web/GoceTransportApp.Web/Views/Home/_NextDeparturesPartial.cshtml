@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<GoceTransportApp.Web.ViewModels.Schedules.NextDepartureViewModel>

@if (Model == null || !Model.Any())
{
    <div class="text-center py-4 text-muted">
        <i class="fas fa-moon fa-2x mb-2 d-block"></i>
        <span class="small">@Localizer["No more departures today. Check back tomorrow."]</span>
    </div>
}
else
{
    <div class="list-group list-group-flush">
        @foreach (var d in Model)
        {
            <a asp-controller="Schedule" asp-action="Details" asp-route-id="@d.ScheduleId"
               class="list-group-item list-group-item-action px-3 py-3 border-0 border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-center" style="min-width:52px;">
                            <div class="fs-4 fw-bold text-primary lh-1">@d.DepartureTime</div>
                            <div class="badge @(d.IsToday ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning") rounded-pill small mt-1">
                                @(d.IsToday ? Localizer["Today"] : Localizer["Tomorrow"])
                            </div>
                        </div>
                        <div>
                            <div class="fw-semibold">@d.FromCity <i class="fas fa-arrow-right text-muted mx-1 small"></i> @d.ToCity</div>
                            <div class="small text-muted"><i class="fas fa-building me-1"></i>@d.OrganizationName</div>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-primary-subtle text-primary rounded-pill small fw-semibold">@d.MinutesUntil</span>
                    </div>
                </div>
            </a>
        }
    </div>
}
