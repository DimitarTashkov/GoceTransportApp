@using GoceTransportApp.Services.Data.Users
@using GoceTransportApp.Web.ViewModels.Streets
@using System.Security.Claims
@using Microsoft.AspNetCore.Mvc.Localization
@model AllStreetsSearchFilterViewModel
@inject IUserService userService
@inject IViewLocalizer Localizer

@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    ViewData["Title"] = "All Streets";
}

<div class="text-center mb-4">
    <i class="fas fa-road fa-3x text-primary mb-3"></i>
    <h1 class="h2 fw-bold">@Localizer["Streets"]</h1>
</div>

<div class="d-flex gap-2 mb-4 flex-wrap align-items-center">
    <form method="get" class="d-flex gap-2 flex-grow-1">
        <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control rounded-pill" placeholder="@Localizer["Search streets..."]" />
        <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search"></i>
        </button>
    </form>
    @if (userId != null)
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i>@Localizer["Add Street"]
        </a>
    }
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model.Streets.Any())
    {
        @foreach (var street in Model.Streets)
        {
            <partial name="_StreetListPartial" model="street" />
        }
    }
    else
    {
        <div class="col-12">
            <p class="text-center text-muted"><i class="fas fa-exclamation-circle me-1"></i>@Localizer["No streets found."]</p>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage - 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                        <i class="fas fa-chevron-left"></i> @Localizer["Previous"]
                    </a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@i&EntitiesPerPage=@Model.EntitiesPerPage">@i</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage + 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                        @Localizer["Next"] <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}
