@using Microsoft.AspNetCore.Mvc.Localization
@model IEnumerable<GoceTransportApp.Web.ViewModels.Organizations.OrganizationDataViewModel>
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "My Organizations";
}

<div class="text-center mb-4">
    <i class="fas fa-building fa-3x text-primary mb-3"></i>
    <h2 class="h2 fw-bold">@Localizer["My Organizations"]</h2>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4"><i class="fas fa-plus me-1"></i> @Localizer["Add New Organization"]</a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model != null && Model.Any())
    {
        @foreach (var organization in Model)
        {
            <div class="col">
                <partial name="_OrganizationCardPartial" model="organization" />
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center">
            <p class="text-muted">@Localizer["You have not created any organizations yet."]</p>
        </div>
    }
</div>
