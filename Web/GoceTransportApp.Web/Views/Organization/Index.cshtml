@using System.Security.Claims
@using GoceTransportApp.Services.Data.Users
@using GoceTransportApp.Web.ViewModels.Organizations;
@using Microsoft.AspNetCore.Mvc.Localization
@model AllOrganizationsSearchFilterViewModel
@inject IUserService userService
@inject IViewLocalizer Localizer

@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    ViewData["Title"] = "Organizations";
}

<div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-4">
    <div>
        <h2 class="fw-bold text-dark mb-2">@Localizer["Our Transport Partners"]</h2>
        <p class="lead text-muted mb-0">@Localizer["Browse the licensed companies that ensure your comfortable and safe journey."]</p>
    </div>
    <div></div>
</div>

<div class="d-flex gap-2 mb-4 flex-wrap align-items-center">
    <form method="get" class="d-flex gap-2 flex-grow-1">
        <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control rounded-pill" placeholder="@Localizer["Search by name..."]" />
        <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search"></i>
        </button>
    </form>
    @if (userId != null)
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i>@Localizer["Add Organization"]
        </a>
    }
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model.Organizations != null && Model.Organizations.Any())
    {
        @foreach (var organization in Model.Organizations)
        {
            <partial name="_OrganizationCardPartial" model="organization" />
        }
    }
    else
    {
        <div class="col-12">
            <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                <div class="fs-1 text-muted mb-3">📭</div>
                <h4 class="fw-semibold">@Localizer["No records found"]</h4>
                <p class="text-muted">@Localizer["No information has been added here yet."]</p>
            </div>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage - 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                        <i class="fas fa-chevron-left"></i> @Localizer["Previous"]
                    </a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@i&EntitiesPerPage=@Model.EntitiesPerPage">@i</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage + 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                        <i class="fas fa-chevron-right"></i> @Localizer["Next"]
                    </a>
                </li>
            }
        </ul>
    </nav>
}
