@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Pricing & Plans";
    var upgradeReason = TempData["UpgradeReason"]?.ToString();
}

<section class="py-5">
    <div class="text-center mb-5">
        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3 fw-semibold">
            <i class="fas fa-gem me-1"></i>@Localizer["Pricing"]
        </span>
        <h1 class="display-5 fw-bold">@Localizer["Choose Your Plan"]</h1>
        <p class="lead text-muted col-lg-7 mx-auto">@Localizer["Unlock more organizations and features for your transport business."]</p>

        <div class="alert alert-info d-flex align-items-start gap-2 rounded-3 px-4 mt-3 text-start col-lg-8 mx-auto" role="alert">
            <i class="fas fa-info-circle mt-1 flex-shrink-0"></i>
            <span>@Localizer["GoceTransportApp is a volunteer, non-profit project. All revenue from paid plans is used solely to cover monthly server hosting costs (Azure) of €15. Support us to keep the platform alive!"]</span>
        </div>

        @if (!string.IsNullOrEmpty(upgradeReason))
        {
            <div class="alert alert-warning d-inline-flex align-items-center gap-2 rounded-3 px-4 mt-3" role="alert">
                <i class="fas fa-lock me-1"></i> @upgradeReason
            </div>
        }
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center mb-5">

        @* Free *@
        <div class="col">
            <div class="card border-0 rounded-4 shadow-sm h-100 text-center">
                <div class="card-body p-4 p-lg-5">
                    <div class="rounded-circle bg-secondary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                        <i class="fas fa-paper-plane fa-2x text-secondary"></i>
                    </div>
                    <h3 class="fw-bold">Free</h3>
                    <p class="text-muted small mb-3">@Localizer["For individual operators"]</p>
                    <div class="display-4 fw-bolder mb-1">€0<small class="fs-5 text-muted fw-normal">/mo</small></div>
                    <p class="text-muted small mb-4">@Localizer["Forever free"]</p>

                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>1 @Localizer["Organization"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Unlimited Schedules"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Analytics Dashboard"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Basic Support"]</li>
                        <li class="mb-2 py-1 text-muted"><i class="fas fa-times-circle text-muted me-2"></i>@Localizer["Email Notifications"]</li>
                        <li class="mb-2 py-1 text-muted"><i class="fas fa-times-circle text-muted me-2"></i>@Localizer["Priority Support"]</li>
                    </ul>

                    <button class="btn btn-outline-secondary rounded-pill w-100 py-2" disabled>
                        <i class="fas fa-check me-1"></i>@Localizer["Current Plan"]
                    </button>
                </div>
            </div>
        </div>

        @* Pro *@
        <div class="col">
            <div class="card border-primary border-2 rounded-4 shadow h-100 text-center position-relative">
                <div class="position-absolute top-0 start-50 translate-middle">
                    <span class="badge bg-primary rounded-pill px-4 py-2 fs-6">
                        <i class="fas fa-star me-1"></i>@Localizer["Most Popular"]
                    </span>
                </div>
                <div class="card-body p-4 p-lg-5 pt-5">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                        <i class="fas fa-rocket fa-2x text-primary"></i>
                    </div>
                    <h3 class="fw-bold text-primary">Pro</h3>
                    <p class="text-muted small mb-3">@Localizer["For growing businesses"]</p>
                    <div class="display-4 fw-bolder mb-1">€4.99<small class="fs-5 text-muted fw-normal">/mo</small></div>
                    <p class="text-muted small mb-4">@Localizer["Billed monthly"]</p>

                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>3</strong> @Localizer["Organizations"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Unlimited Schedules"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Analytics Dashboard"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Basic Support"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Email Notifications"]</li>
                        <li class="mb-2 py-1 text-muted"><i class="fas fa-times-circle text-muted me-2"></i>@Localizer["Priority Support"]</li>
                    </ul>

                    <a asp-controller="ContactForm" asp-action="Create" class="btn btn-primary rounded-pill w-100 py-2 fw-semibold">
                        <i class="fas fa-envelope me-1"></i>@Localizer["Contact Us"]
                    </a>
                </div>
            </div>
        </div>

        @* Enterprise *@
        <div class="col">
            <div class="card border-0 rounded-4 shadow-sm h-100 text-center">
                <div class="card-body p-4 p-lg-5">
                    <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                        <i class="fas fa-crown fa-2x text-warning"></i>
                    </div>
                    <h3 class="fw-bold">@Localizer["Sponsor"]</h3>
                    <p class="text-muted small mb-3">@Localizer["For sponsors"]</p>
                    <div class="display-4 fw-bolder mb-1">€9.99<small class="fs-5 text-muted fw-normal">/mo</small></div>
                    <p class="text-muted small mb-4">@Localizer["Billed monthly"]</p>

                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>@Localizer["Unlimited"]</strong> @Localizer["Organizations"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Unlimited Schedules"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Analytics Dashboard"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Email Notifications"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Priority Support"]</li>
                    </ul>

                    <a asp-controller="ContactForm" asp-action="Create" class="btn btn-warning rounded-pill w-100 py-2 fw-semibold text-dark">
                        <i class="fas fa-envelope me-1"></i>@Localizer["Contact Us"]
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- FAQ-style comparison -->
    <div class="card border-0 shadow-sm rounded-4 p-4 p-lg-5 mb-4">
        <h4 class="fw-bold text-center mb-4">@Localizer["Compare Plans"]</h4>
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0">
                <thead>
                    <tr>
                        <th class="text-muted small fw-semibold" style="width: 40%;">@Localizer["Feature"]</th>
                        <th class="text-center small fw-semibold">Free</th>
                        <th class="text-center small fw-semibold text-primary">Pro</th>
                        <th class="text-center small fw-semibold">@Localizer["Sponsor"]</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="small">@Localizer["Organizations"]</td>
                        <td class="text-center">1</td>
                        <td class="text-center fw-semibold text-primary">3</td>
                        <td class="text-center fw-semibold">@Localizer["Unlimited"]</td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Schedules"]</td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Analytics Dashboard"]</td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Basic Support"]</td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Email Notifications"]</td>
                        <td class="text-center"><i class="fas fa-times text-muted"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Priority Support"]</td>
                        <td class="text-center"><i class="fas fa-times text-muted"></i></td>
                        <td class="text-center"><i class="fas fa-times text-muted"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-center">
        <a asp-action="UserOrganizations" class="btn btn-link text-muted text-decoration-none">
            <i class="fas fa-arrow-left me-1"></i>@Localizer["Back to My Organizations"]
        </a>
    </div>
</section>
