@model GoceTransportApp.Web.ViewModels.Schedules.EditScheduleInputModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Edit Schedule";
    var returnUrl = Context.Request.Headers["Referer"].ToString();
    if (string.IsNullOrEmpty(returnUrl)) returnUrl = Url.Action("Index", "Route");
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <i class="fas fa-calendar-alt fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Edit Schedule"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input asp-for="OrganizationId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Day" class="form-label text-muted">@Localizer["Day"]</label>
                        <select asp-for="Day" class="form-select rounded-3">
                            <option value="">-- @Localizer["Select a Day"] --</option>
                            <option value="Monday">@Localizer["Monday"]</option>
                            <option value="Tuesday">@Localizer["Tuesday"]</option>
                            <option value="Wednesday">@Localizer["Wednesday"]</option>
                            <option value="Thursday">@Localizer["Thursday"]</option>
                            <option value="Friday">@Localizer["Friday"]</option>
                            <option value="Saturday">@Localizer["Saturday"]</option>
                            <option value="Sunday">@Localizer["Sunday"]</option>
                        </select>
                        <span asp-validation-for="Day" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Departure" class="form-label text-muted">@Localizer["Departure Time"]</label>
                        <input asp-for="Departure" type="time" class="form-control rounded-3" />
                        <span asp-validation-for="Departure" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Arrival" class="form-label text-muted">@Localizer["Arrival Time"]</label>
                        <input asp-for="Arrival" type="time" class="form-control rounded-3" />
                        <span asp-validation-for="Arrival" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="VehicleId" class="form-label text-muted">@Localizer["Vehicle"]</label>
                        <select asp-for="VehicleId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a vehicle"]</option>
                            @foreach (var vehicle in Model.Vehicles)
                            {
                                <option value="@vehicle.Value">@vehicle.Text</option>
                            }
                        </select>
                        <span asp-validation-for="VehicleId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="RouteId" class="form-label text-muted">@Localizer["Route"]</label>
                        <select asp-for="RouteId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a route"]</option>
                            @foreach (var route in Model.Routes)
                            {
                                <option value="@route.Value">@route.Text</option>
                            }
                        </select>
                        <span asp-validation-for="RouteId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 p-3 border border-warning rounded-3 bg-warning bg-opacity-10">
                        <label asp-for="LiveStatus" class="form-label fw-semibold text-warning-emphasis">
                            <i class="fas fa-triangle-exclamation me-1"></i>@Localizer["Live Status (Real-Time Alert)"]
                        </label>
                        <input asp-for="LiveStatus" type="text" class="form-control rounded-3"
                               placeholder="@Localizer["e.g. Delayed 20 min / Cancelled"]" maxlength="200" />
                        <div class="form-text">@Localizer["Leave empty to clear the alert. Passengers will be notified instantly."]</div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>@Localizer["Update"]
                    </button>
                    <a href="@returnUrl" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-times me-2"></i>@Localizer["Cancel"]
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
