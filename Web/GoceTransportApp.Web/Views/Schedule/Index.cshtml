@using System.Security.Claims
@using GoceTransportApp.Services.Data.Users
@model GoceTransportApp.Web.ViewModels.Schedules.AllSchedulesSearchFilterViewModel
@inject IUserService userService

@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    ViewData["Title"] = "Schedules";
}

<div class="text-center mb-4">
    <i class="fas fa-calendar-alt fa-3x text-primary mb-3"></i>
    <h1 class="h2 fw-bold">Schedules</h1>
</div>

<div class="d-flex gap-2 mb-4 flex-wrap align-items-end">
    <form method="get" class="d-flex gap-2 flex-wrap flex-grow-1 align-items-end">
        <div>
            <label asp-for="DayFilter" class="form-label text-muted small"><i class="fas fa-calendar-day me-1"></i>Day</label>
            <select asp-for="DayFilter" class="form-select rounded-pill">
                <option value="">-- All Days --</option>
                <option value="Monday">Monday</option>
                <option value="Tuesday">Tuesday</option>
                <option value="Wednesday">Wednesday</option>
                <option value="Thursday">Thursday</option>
                <option value="Friday">Friday</option>
                <option value="Saturday">Saturday</option>
                <option value="Sunday">Sunday</option>
            </select>
        </div>
        <div>
            <label for="TimeFilter" class="form-label text-muted small">Time</label>
            <input type="time" name="TimeFilter" value="@Model.TimeFilter?.ToString(@"hh\:mm")" class="form-control rounded-pill" id="filterTime" />
        </div>
        <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search"></i>
        </button>
    </form>
    @if (userId != null)
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i>Add Schedule
        </a>
    }
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var item in Model.Schedules)
    {
        <partial name="_ScheduleCard" model="item" />
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?DayFilter=@Model.DayFilter&TimeFilter=@Model.TimeFilter&CurrentPage=@(Model.CurrentPage - 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?DayFilter=@Model.DayFilter&TimeFilter=@Model.TimeFilter&CurrentPage=@i&EntitiesPerPage=@Model.EntitiesPerPage">@i</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?DayFilter=@Model.DayFilter&TimeFilter=@Model.TimeFilter&CurrentPage=@(Model.CurrentPage + 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts{
    <script src="~/js/timePlaceholderHandler.js"></script>
}
