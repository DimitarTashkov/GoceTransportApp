@using GoceTransportApp.Web.ViewModels.ContactForms
@model AllFormsSearchFilterViewModel

<form method="get" class="mb-4">
    <div class="d-flex gap-2">
        <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control rounded-pill" placeholder="Search for user..." />
        <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search"></i>
        </button>
    </div>
</form>

<div class="table-responsive bg-white rounded-4 shadow-sm p-3">
    <table class="table table-borderless table-hover align-middle mb-0">
        <thead>
            <tr>
                <th class="text-uppercase text-secondary fw-semibold small">#</th>
                <th class="text-uppercase text-secondary fw-semibold small">Username</th>
                <th class="text-uppercase text-secondary fw-semibold small">Title</th>
                <th class="text-uppercase text-secondary fw-semibold small">Date Submitted</th>
                <th class="text-uppercase text-secondary fw-semibold small">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Forms.Any())
            {
                var index = 1;
                foreach (var contactForm in Model.Forms)
                {
                    <tr>
                        <td>@index</td>
                        <td>@contactForm.Username</td>
                        <td>@contactForm.Title</td>
                        <td>@contactForm.DateSubmitted.ToString("f")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@contactForm.Id" class="btn btn-outline-primary btn-sm rounded-pill">
                                <i class="fas fa-eye"></i> View
                            </a>
                            <a asp-action="Delete" asp-route-id="@contactForm.Id" class="btn btn-outline-danger btn-sm rounded-pill">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    index++;
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No contact forms found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage - 1)&EntitiesPerPage=@Model.EntitiesPerPage">Previous</a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@i&EntitiesPerPage=@Model.EntitiesPerPage">@i</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage + 1)&EntitiesPerPage=@Model.EntitiesPerPage">Next</a>
                </li>
            }
        </ul>
    </nav>
}
