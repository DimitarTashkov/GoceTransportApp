@using GoceTransportApp.Services.Data.Users
@using System.Security.Claims
@using static GoceTransportApp.Common.GlobalConstants
@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Streets.StreetDataViewModel
@inject IUserService userService
@inject IViewLocalizer Localizer

@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAdmin = User.IsInRole(AdministratorRoleName);
}

<div class="col">
    <div class="card border-0 shadow-sm rounded-4 h-100 hover-elevate">
        <div class="card-body p-4 d-flex flex-column">
            <div class="mb-3">
                <i class="fas fa-road fa-2x text-primary mb-2"></i>
                <h5 class="card-title fw-semibold mb-0">@Model.Name</h5>
            </div>
            @if (isAdmin)
            {
                <div class="mt-auto pt-3 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning rounded-pill flex-grow-1">
                        <i class="fas fa-edit"></i> @Localizer["Edit"]
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger rounded-pill" title="@Localizer["Delete"]">
                            <i class="fas fa-trash"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
