@using System.Security.Claims
@using GoceTransportApp.Data.Models.Enumerations
@using GoceTransportApp.Services.Data.Users
@using static GoceTransportApp.Common.GlobalConstants
@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Organizations.OrganizationDataViewModel
@inject IUserService userService
@inject IViewLocalizer Localizer
@{
    var organizationId = Model.Id;
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isFounder = await userService.HasUserCreatedOrganizationAsync(userId, organizationId);
    var isAdmin = User.IsInRole(AdministratorRoleName);
    var isTopResult = Model.FounderTier == MembershipTier.Pro || Model.FounderTier == MembershipTier.Enterprise;
    var isFreeProfile = Model.FounderTier == MembershipTier.Free;
}
<div class="col">
    <div class="card h-100 border-0 shadow-sm rounded-4 hover-elevate @(isTopResult ? "border border-warning border-2" : "") @(isFreeProfile ? "opacity-75" : "")">

        <div class="card-header bg-white border-0 pt-4 pb-0 d-flex align-items-center gap-3">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="rounded-circle border flex-shrink-0"
                     style="width:64px;height:64px;object-fit:cover;" alt="Logo" />
            }
            else
            {
                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold fs-4 flex-shrink-0"
                     style="width:64px;height:64px;">
                    @Model.Name.Substring(0, 1).ToUpper()
                </div>
            }
            <div class="overflow-hidden">
                <h5 class="card-title mb-0 fw-bold text-truncate">@Model.Name</h5>
                <p class="text-muted small mb-0 text-truncate">
                    <i class="fas fa-user me-1"></i>@Model.Founder
                </p>
                @if (isTopResult)
                {
                    <span class="badge bg-warning text-dark mt-1">
                        <i class="fas fa-star me-1"></i>@Localizer["Top Result"]
                    </span>
                }
            </div>
        </div>

        <div class="card-body px-4 py-3">
            @if (!string.IsNullOrEmpty(Model.Address))
            {
                <p class="text-muted small mb-0">
                    <i class="fas fa-map-marker-alt me-1 text-primary"></i>@Model.Address
                </p>
            }
            else
            {
                <p class="text-muted small mb-0 fst-italic">@Localizer["No address provided"]</p>
            }
        </div>

        <div class="card-footer bg-white border-0 pb-4 px-4 d-flex gap-2">
            <a asp-action="Details" asp-route-id="@Model.Id"
               class="btn btn-sm btn-outline-secondary rounded-pill flex-grow-1">
                <i class="fas fa-info-circle me-1"></i>@Localizer["Details"]
            </a>
            @if (isFounder || isAdmin)
            {
                <a asp-action="Edit" asp-controller="Organization" asp-route-id="@Model.Id"
                   class="btn btn-sm btn-outline-secondary rounded-pill" title="@Localizer["Edit"]">
                    <i class="fas fa-edit"></i>
                </a>
                <a asp-action="Delete" asp-controller="Organization" asp-route-id="@Model.Id"
                   class="btn btn-sm btn-outline-secondary rounded-pill" title="@Localizer["Delete"]">
                    <i class="fas fa-trash-alt"></i>
                </a>
            }
        </div>

    </div>
</div>
