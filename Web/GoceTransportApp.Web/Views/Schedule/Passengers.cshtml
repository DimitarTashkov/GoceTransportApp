@model GoceTransportApp.Web.ViewModels.Schedules.PassengerListViewModel
@using static GoceTransportApp.Common.ResultMessages.GeneralMessages
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Passenger List";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-controller="Schedule" asp-action="Details"
       asp-route-id="@Model.ScheduleId"
       asp-route-organizationId="@Model.OrganizationId"
       class="btn btn-outline-secondary rounded-pill">
        <i class="fas fa-arrow-left me-1"></i> @Localizer["Back"]
    </a>
    <div>
        <h2 class="fw-bold mb-0">@Localizer["Passenger List"]</h2>
        <p class="text-muted small mb-0">
            <i class="fas fa-route me-1"></i>@Model.FromCity → @Model.ToCity
            &nbsp;|&nbsp;
            <i class="fas fa-calendar me-1"></i>@Model.Day &nbsp;@Model.DepartingTime
        </p>
    </div>
</div>

@if (TempData[nameof(SuccessMessage)] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData[nameof(SuccessMessage)]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        @if (Model.Passengers.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">@Localizer["Passenger"]</th>
                            <th class="text-center">@Localizer["Status"]</th>
                            <th class="text-center pe-4">@Localizer["Action"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var passenger in Model.Passengers)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:38px;height:38px">
                                            <i class="fas fa-user text-primary"></i>
                                        </div>
                                        <span class="fw-semibold">@passenger.CustomerName</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (passenger.IsBoarded)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">
                                            <i class="fas fa-check me-1"></i>@Localizer["Boarded"]
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-2">
                                            <i class="fas fa-clock me-1"></i>@Localizer["Waiting"]
                                        </span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <form asp-controller="Schedule" asp-action="Board" method="post">
                                        <input type="hidden" name="customerId" value="@passenger.CustomerId" />
                                        <input type="hidden" name="ticketId" value="@passenger.TicketId" />
                                        <input type="hidden" name="scheduleId" value="@Model.ScheduleId" />
                                        <input type="hidden" name="organizationId" value="@Model.OrganizationId" />
                                        @if (passenger.IsBoarded)
                                        {
                                            <button type="submit" class="btn btn-outline-warning btn-sm rounded-pill">
                                                <i class="fas fa-undo me-1"></i>@Localizer["Unboard"]
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-success btn-sm rounded-pill">
                                                <i class="fas fa-check me-1"></i>@Localizer["Board"]
                                            </button>
                                        }
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="px-4 py-3 border-top text-muted small">
                @{
                    var boardedCount = Model.Passengers.Count(p => p.IsBoarded);
                    var totalCount = Model.Passengers.Count();
                }
                <i class="fas fa-users me-1"></i>
                <strong>@boardedCount / @totalCount</strong> @Localizer["passengers boarded"]
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users fa-3x text-muted mb-3"></i>
                <p class="text-muted">No passengers have purchased tickets for this schedule.</p>
            </div>
        }
    </div>
</div>
