@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    this.ViewData["Title"] = "Privacy Policy";
    ViewData["MetaDescription"] = "GoceTrans Privacy Policy — how we collect, use and protect your personal data.";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="mb-4">
            <h1 class="fw-bold">@Localizer["Privacy Policy"]</h1>
            <p class="text-muted small">@Localizer["Last updated: January 1, 2025"]</p>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3"><i class="fas fa-info-circle text-primary me-2"></i>@Localizer["1. Who We Are"]</h2>
                <p>@Localizer["GoceTrans is an online platform that helps passengers find routes, browse schedules, and book tickets for intercity bus travel. We are a digital service — not a transport operator — and we take your privacy seriously."]</p>
                <p>@Localizer["If you have any questions about how we handle your data,"] <a asp-controller="ContactForm" asp-action="Create" class="text-decoration-none">@Localizer["get in touch with us here"]</a>.</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3"><i class="fas fa-database text-primary me-2"></i>@Localizer["2. What Data We Collect"]</h2>
                <p>@Localizer["We only collect what we actually need to run the service:"]</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0"><strong>@Localizer["Account data:"]</strong> @Localizer["your email and username. Your password is stored as a secure hash — we never see it in plain text."]</li>
                    <li class="list-group-item px-0"><strong>@Localizer["Booking data:"]</strong> @Localizer["tickets you've purchased, your travel history, and any cancellations."]</li>
                    <li class="list-group-item px-0"><strong>@Localizer["Organization data:"]</strong> @Localizer["name, routes, and schedules — only if you register a transport organization."]</li>
                    <li class="list-group-item px-0"><strong>@Localizer["Contact messages:"]</strong> @Localizer["messages you send through our contact form."]</li>
                    <li class="list-group-item px-0"><strong>@Localizer["Technical data:"]</strong> @Localizer["basic server logs (IP address, browser type) kept for 30 days for security purposes."]</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3"><i class="fas fa-balance-scale text-primary me-2"></i>@Localizer["3. Why We Process Your Data"]</h2>
                <p>@Localizer["We process your data for clear reasons:"]</p>
                <ul>
                    <li>@Localizer["To create and manage your account so you can use the platform."]</li>
                    <li>@Localizer["To handle ticket purchases and keep your booking history."]</li>
                    <li>@Localizer["To send you notifications about your trips."]</li>
                    <li>@Localizer["To keep the platform secure and prevent abuse."]</li>
                    <li>@Localizer["To respond to messages you send us."]</li>
                </ul>
                <p class="mb-0 text-muted small">@Localizer["The legal basis for most of this is fulfilling the service contract with you (GDPR Art. 6(1)(b)), and in some cases our legitimate interests in keeping the platform safe (Art. 6(1)(f))."]</p>
            </div>
        </div>


        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3"><i class="fas fa-share-alt text-primary me-2"></i>@Localizer["4. Who We Share Data With"]</h2>
                <p>@Localizer["We do not sell your data. We only share it where necessary:"]</p>
                <ul>
                    <li>@Localizer["Transport operators — they can see booking data for their own routes."]</li>
                    <li>@Localizer["Email provider — used only to deliver messages related to your account or trips."]</li>
                    <li>@Localizer["Hosting infrastructure — your data is stored on servers within the EU."]</li>
                    <li>@Localizer["Authorities — only when we are legally required to do so."]</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3"><i class="fas fa-user-shield text-primary me-2"></i>@Localizer["5. Your Rights"]</h2>
                <p>@Localizer["You have full control over your personal data. You can:"]</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success mt-1"></i>
                            <div><strong>@Localizer["Access your data"]</strong> — @Localizer["ask us for a copy of everything we hold about you"]</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success mt-1"></i>
                            <div><strong>@Localizer["Correct your data"]</strong> — @Localizer["fix anything that's wrong or outdated"]</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success mt-1"></i>
                            <div><strong>@Localizer["Delete your data"]</strong> — @Localizer["request full removal of your account and data"]</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success mt-1"></i>
                            <div><strong>@Localizer["Export your data"]</strong> — @Localizer["receive it in a readable format"]</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success mt-1"></i>
                            <div><strong>@Localizer["Object to processing"]</strong> — @Localizer["where we rely on legitimate interests"]</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success mt-1"></i>
                            <div><strong>@Localizer["Restrict processing"]</strong> — @Localizer["limit what we do with your data"]</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>


        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3"><i class="fas fa-cookie-bite text-primary me-2"></i>@Localizer["8. Cookies"]</h2>
                <p>@Localizer["We use only the cookies that are strictly necessary to run the service:"]</p>
                <ul>

                    <li>@Localizer["Cookie consent — remembers that you've accepted this notice."]</li>
                </ul>
                <p class="mb-0">@Localizer["We don't use advertising, analytics, or any third-party tracking cookies."]</p>
            </div>
        </div>

        <p class="text-muted small">
            @Localizer["This policy may be updated from time to time. When it changes, we'll update the date at the top."]
            <a asp-controller="Home" asp-action="Terms" class="text-decoration-none">@Localizer["Terms of Service"]</a> |
            <a asp-controller="ContactForm" asp-action="Create" class="text-decoration-none">@Localizer["Contact Us"]</a>
        </p>
    </div>
</div>
