@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Schedules.TravelSearchViewModel
@using GoceTransportApp.Data.Models
@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section: Search-first layout -->
<section class="py-4 py-lg-5">
    <div class="row align-items-center g-4">

        <!-- Search Form — first on mobile (order-1), right on desktop (order-lg-2) -->
        <div class="col-12 col-lg-5 order-1 order-lg-2">
            <div class="card border-0 shadow-lg rounded-4 p-4 bg-body">
                <h2 class="fw-bold mb-1 fs-4">
                    <i class="fas fa-bus-alt text-primary me-2"></i>@Localizer["Find Your Bus"]
                </h2>
                <p class="text-muted small mb-4">@Localizer["Search available schedules by origin, destination and date."]</p>
                <form asp-controller="Schedule" asp-action="Search" method="get">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">@Localizer["From"]</label>
                        <select name="FromCityId" class="form-select form-select-lg rounded-3">
                            <option value="">— @Localizer["Select city"] —</option>
                            @foreach (var city in Model.Cities)
                            {
                                if (Model.FromCityId == city.Id.ToString())
                                {
                                    <option value="@city.Id" selected>@city.Name</option>
                                }
                                else
                                {
                                    <option value="@city.Id">@city.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">@Localizer["To"]</label>
                        <select name="ToCityId" class="form-select form-select-lg rounded-3">
                            <option value="">— @Localizer["Select city"] —</option>
                            @foreach (var city in Model.Cities)
                            {
                                if (Model.ToCityId == city.Id.ToString())
                                {
                                    <option value="@city.Id" selected>@city.Name</option>
                                }
                                else
                                {
                                    <option value="@city.Id">@city.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">@Localizer["Date of Travel"]</label>
                        <input type="date" name="DepartureDate" class="form-control form-control-lg rounded-3"
                               value="@(Model.DepartureDate.HasValue ? Model.DepartureDate.Value.ToString("yyyy-MM-dd") : "")" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-3 fw-bold py-3 fs-5">
                        <i class="fas fa-search me-2"></i>@Localizer["Search"]
                    </button>
                </form>
            </div>
        </div>

        <!-- Hero Text — second on mobile (order-2), left on desktop (order-lg-1) -->
        <div class="col-12 col-lg-7 order-2 order-lg-1">
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3 fw-semibold">
                <i class="fas fa-map-marked-alt me-1"></i>@Localizer["Travel Made Simple"]
            </span>
            <h1 class="display-5 fw-bold mb-3 lh-sm">
                @Localizer["Find Your Next"]
                <span class="text-primary">@Localizer["Journey"]</span>
            </h1>
            <p class="lead text-muted mb-4">
                @Localizer["Search routes, compare schedules, and book tickets — all in one place. Your adventure starts here."]
            </p>

            <!-- Quick access pills -->
            <div class="d-flex flex-wrap gap-2 mb-4">
                <a asp-controller="Schedule" asp-action="Index" class="btn btn-outline-primary rounded-pill fw-semibold">
                    <i class="fas fa-calendar-alt me-1"></i>@Localizer["All Schedules"]
                </a>
                <a asp-controller="Organization" asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-semibold">
                    <i class="fas fa-building me-1"></i>@Localizer["Organizations"]
                </a>
                <a asp-controller="Route" asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-semibold">
                    <i class="fas fa-route me-1"></i>@Localizer["Routes"]
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Stats Bar -->
<section class="py-3">
    <div class="row g-3 text-center">
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-primary bg-opacity-10 rounded-4 p-3">
                <div class="fw-bold fs-3 text-primary">500+</div>
                <div class="text-muted small fw-semibold">@Localizer["Routes"]</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-success bg-opacity-10 rounded-4 p-3">
                <div class="fw-bold fs-3 text-success">50+</div>
                <div class="text-muted small fw-semibold">@Localizer["Organizations"]</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-warning bg-opacity-10 rounded-4 p-3">
                <div class="fw-bold fs-3 text-warning">100+</div>
                <div class="text-muted small fw-semibold">@Localizer["Cities"]</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-info bg-opacity-10 rounded-4 p-3">
                <div class="fw-bold fs-3 text-info">10K+</div>
                <div class="text-muted small fw-semibold">@Localizer["Tickets"]</div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold mb-2">@Localizer["How It Works"]</h2>
        <p class="text-muted lead">@Localizer["Three simple steps to plan your journey."]</p>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-4 hover-elevate">
                <div class="card-body">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4" style="width:72px;height:72px">
                        <i class="fas fa-map-marked-alt fa-2x text-primary"></i>
                    </div>
                    <h5 class="fw-bold mb-2">@Localizer["1. Find a Route"]</h5>
                    <p class="text-muted small mb-0">@Localizer["Browse all available routes, filter by departing and arriving city, and find the connection that fits your journey."]</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-4 hover-elevate">
                <div class="card-body">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4" style="width:72px;height:72px">
                        <i class="fas fa-clock fa-2x text-primary"></i>
                    </div>
                    <h5 class="fw-bold mb-2">@Localizer["2. Check the Schedule"]</h5>
                    <p class="text-muted small mb-0">@Localizer["See departure times, days of operation, and available vehicles."]</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-4 hover-elevate">
                <div class="card-body">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4" style="width:72px;height:72px">
                        <i class="fas fa-ticket-alt fa-2x text-primary"></i>
                    </div>
                    <h5 class="fw-bold mb-2">@Localizer["3. Get Your Ticket"]</h5>
                    <p class="text-muted small mb-0">@Localizer["Browse available tickets, check validity dates and pricing, and keep track of all your purchased tickets in one place."]</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="py-5">
    <div class="row align-items-center g-5">
        <div class="col-md-6">
            <div class="text-center">
                <img src="~/images/travel_illustration.png" alt="Travel Illustration" class="img-fluid">
            </div>
        </div>
        <div class="col-md-6">
            <h2 class="fw-bold mb-4">@Localizer["Everything You Need in One App"]</h2>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px">
                        <i class="fas fa-route text-primary"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">@Localizer["Routes"]</h6>
                        <p class="text-muted small mb-0">@Localizer["Discover all travel routes between cities, with complete street-level details and distance information."]</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px">
                        <i class="fas fa-calendar-alt text-primary"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">@Localizer["Schedules"]</h6>
                        <p class="text-muted small mb-0">@Localizer["View full operating schedules for every route — filter by day and time to plan your trip with precision."]</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px">
                        <i class="fas fa-building text-primary"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">@Localizer["Organizations"]</h6>
                        <p class="text-muted small mb-0">@Localizer["Browse transport organizations, their fleets, and the routes and drivers they manage across the network."]</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px">
                        <i class="fas fa-bus text-primary"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">@Localizer["Vehicles & Drivers"]</h6>
                        <p class="text-muted small mb-0">@Localizer["Get detailed information about the vehicles in service and the experienced drivers operating each route."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Access -->
<section class="py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold mb-2">@Localizer["Quick Access"]</h2>
        <p class="text-muted lead">@Localizer["Jump straight to what you need."]</p>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        <div class="col">
            <a asp-controller="Route" asp-action="Index" class="card border-0 shadow-sm rounded-4 h-100 text-center text-decoration-none p-4 hover-elevate">
                <div class="card-body">
                    <i class="fas fa-route fa-2x text-primary mb-3"></i>
                    <h6 class="fw-bold text-body mb-1">@Localizer["Routes"]</h6>
                    <p class="text-muted small mb-0">@Localizer["All travel routes"]</p>
                </div>
            </a>
        </div>
        <div class="col">
            <a asp-controller="Schedule" asp-action="Index" class="card border-0 shadow-sm rounded-4 h-100 text-center text-decoration-none p-4 hover-elevate">
                <div class="card-body">
                    <i class="fas fa-calendar-alt fa-2x text-primary mb-3"></i>
                    <h6 class="fw-bold text-body mb-1">@Localizer["Schedules"]</h6>
                    <p class="text-muted small mb-0">@Localizer["Departure times"]</p>
                </div>
            </a>
        </div>
        <div class="col">
            <a asp-controller="Ticket" asp-action="Index" class="card border-0 shadow-sm rounded-4 h-100 text-center text-decoration-none p-4 hover-elevate">
                <div class="card-body">
                    <i class="fas fa-ticket-alt fa-2x text-primary mb-3"></i>
                    <h6 class="fw-bold text-body mb-1">@Localizer["Tickets"]</h6>
                    <p class="text-muted small mb-0">@Localizer["Available tickets"]</p>
                </div>
            </a>
        </div>
        <div class="col">
            <a asp-controller="Organization" asp-action="Index" class="card border-0 shadow-sm rounded-4 h-100 text-center text-decoration-none p-4 hover-elevate">
                <div class="card-body">
                    <i class="fas fa-building fa-2x text-primary mb-3"></i>
                    <h6 class="fw-bold text-body mb-1">@Localizer["Organizations"]</h6>
                    <p class="text-muted small mb-0">@Localizer["Transport operators"]</p>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- Partner CTA (for unauthenticated / owners) -->
@if (!this.SignInManager.IsSignedIn(this.User))
{
    <section class="py-5 my-4">
        <div class="card border-0 bg-primary bg-opacity-10 rounded-4 overflow-hidden">
            <div class="card-body p-5">
                <div class="row align-items-center g-4">
                    <div class="col-lg-7">
                        <span class="badge bg-primary rounded-pill px-3 py-2 mb-3">
                            <i class="fas fa-handshake me-1"></i>@Localizer["For Business"]
                        </span>
                        <h2 class="fw-bold mb-3">@Localizer["Own a Transport Company?"]</h2>
                        <p class="text-muted mb-4 fs-6">
                            @Localizer["Expand your business by joining our platform. Manage routes, schedules, vehicles, and sell tickets online — all from one dashboard."]
                        </p>
                        <div class="d-flex gap-3 flex-wrap">
                            <a asp-controller="Organization" asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4">
                                <i class="fas fa-plus-circle me-2"></i>@Localizer["Register Organization"]
                            </a>
                            <a asp-controller="Organization" asp-action="Upgrade" class="btn btn-outline-primary btn-lg rounded-pill px-4">
                                <i class="fas fa-gem me-2"></i>@Localizer["View Plans"]
                            </a>
                        </div>
                    </div>
                    <div class="col-lg-5 text-center">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="card border-0 shadow-sm rounded-4 p-3 bg-body">
                                    <i class="fas fa-chart-line fa-2x text-primary mb-2"></i>
                                    <div class="fw-bold small">@Localizer["Analytics"]</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card border-0 shadow-sm rounded-4 p-3 bg-body">
                                    <i class="fas fa-users fa-2x text-success mb-2"></i>
                                    <div class="fw-bold small">@Localizer["Reach Customers"]</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card border-0 shadow-sm rounded-4 p-3 bg-body">
                                    <i class="fas fa-headset fa-2x text-warning mb-2"></i>
                                    <div class="fw-bold small">@Localizer["Support"]</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card border-0 shadow-sm rounded-4 p-3 bg-body">
                                    <i class="fas fa-shield-alt fa-2x text-info mb-2"></i>
                                    <div class="fw-bold small">@Localizer["Secure"]</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- Info Cards -->
<div class="row g-4 mt-2">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 p-4 hover-elevate">
            <div class="card-body text-center">
                <i class="fas fa-info-circle fa-2x text-primary mb-3"></i>
                <h5 class="fw-bold mb-2">@Localizer["About Us"]</h5>
                <p class="text-muted small mb-4">@Localizer["Learn more about GoceTransportApp and our mission to make travel planning easier for everyone."]</p>
                <a asp-controller="Home" asp-action="AboutUs" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="fas fa-info me-1"></i>@Localizer["Learn More"]
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 p-4 hover-elevate">
            <div class="card-body text-center">
                <i class="fas fa-envelope fa-2x text-primary mb-3"></i>
                <h5 class="fw-bold mb-2">@Localizer["Contact Us"]</h5>
                <p class="text-muted small mb-4">@Localizer["Have a question or feedback? Our team is happy to help..."]</p>
                <a asp-controller="ContactForm" asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="fas fa-paper-plane me-1"></i>@Localizer["Contact"]
                </a>
            </div>
        </div>
    </div>
</div>
