@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Streets.StreetInputModel
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Create Street";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <i class="fas fa-road fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Create Street"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Create" method="post">
                    <div class="form-floating mb-4">
                        <input asp-for="Street" class="form-control rounded-3" placeholder="@Localizer["Street Name"]" />
                        <label asp-for="Street" class="form-label text-muted">@Localizer["Street Name"]</label>
                        <span asp-validation-for="Street" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>@Localizer["Save"]
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-arrow-left me-2"></i>@Localizer["Cancel"]
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
