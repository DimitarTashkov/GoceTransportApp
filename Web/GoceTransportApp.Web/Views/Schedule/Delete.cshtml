@model GoceTransportApp.Web.ViewModels.Schedules.RemoveScheduleViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Delete Schedule";
}

<h1 class="text-center text-danger mt-4">@ViewData["Title"]</h1>

<div class="row justify-content-center">
<div class="col-lg-7">
<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">
        <p class="text-center">@Localizer["Are you sure you want to delete this schedule?"]</p>
        <ul class="list-group">
            <li class="list-group-item"><strong>@Localizer["Day"]:</strong> @Model.Day</li>
            <li class="list-group-item"><strong>@Localizer["Departing"]:</strong> @Model.Departing</li>
            <li class="list-group-item"><strong>@Localizer["Arriving"]:</strong> @Model.Arriving</li>
            <li class="list-group-item"><strong>@Localizer["From"]:</strong> @Model.FromCity</li>
            <li class="list-group-item"><strong>@Localizer["To"]:</strong> @Model.ToCity</li>
        </ul>
        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <input asp-for="OrganizationId" type="hidden" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger flex-grow-1">
                    <i class="fas fa-trash-alt"></i> @Localizer["Confirm Delete"]
                </button>
                <a asp-controller="Organization" asp-action="Details" asp-route-id="@Model.OrganizationId" class="btn btn-secondary"><i class="fas fa-times"></i> @Localizer["Cancel"]</a>
            </div>

        </form>
    </div>
</div>
</div>
</div>
