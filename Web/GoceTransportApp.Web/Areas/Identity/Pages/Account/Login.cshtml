@page
@model LoginModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Log in"].Value;
}

<div class="row justify-content-center py-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="fas fa-sign-in-alt fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Welcome back"]</h1>
            <p class="text-muted">@Localizer["Sign in to your account"]</p>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Input.Email">@Localizer["Email"]</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" type="password" class="form-control rounded-3 password-field" autocomplete="current-password" placeholder="Password" />
                        <label asp-for="Input.Password">@Localizer["Password"]</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">@Localizer["Remember me"]</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="showPasswordToggle">
                            <label class="form-check-label" for="showPasswordToggle">@Localizer["Show password"]</label>
                        </div>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-sign-in-alt me-2"></i>@Localizer["Log in"]
                    </button>

                    <p class="text-center mt-4 mb-0 text-muted small">
                        @Localizer["Don't have an account?"]
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-semibold">@Localizer["Register"]</a>
                    </p>
                </form>

                @if (Model.ExternalLogins?.Count > 0)
                {
                    <div class="d-flex align-items-center my-4">
                        <hr class="flex-grow-1" />
                        <span class="px-3 text-muted small">@Localizer["or"]</span>
                        <hr class="flex-grow-1" />
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger rounded-3" role="alert">
                            <strong>@Localizer["Warning:"]</strong> @Model.ErrorMessage
                        </div>
                    }
                    <form asp-page-handler="GoogleLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <button type="submit" class="btn btn-outline-dark w-100 mb-2 rounded-pill" title="@Localizer["Sign in with Google"]">
                            <i class="bi bi-google me-2"></i> @Localizer["Sign in with Google"]
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/showPassword.js"></script>
}
