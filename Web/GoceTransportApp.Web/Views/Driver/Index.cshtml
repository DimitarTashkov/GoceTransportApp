@using GoceTransportApp.Services.Data.Users
@using System.Security.Claims
@model IEnumerable<GoceTransportApp.Web.ViewModels.Drivers.DriverDataViewModel>
@inject IUserService userService
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    ViewData["Title"] = "All Drivers";
}

<div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-4">
    <div>
        <h2 class="fw-bold text-dark mb-2">@Localizer["Our Team"]</h2>
        <p class="lead text-muted mb-0">@Localizer["Meet the professionals behind the wheel you trust with your journey."]</p>
    </div>
    <div></div>
</div>

@if (userId != null)
{
    <div class="d-flex justify-content-end mb-4">
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i>@Localizer["Add Driver"]
        </a>
    </div>
}

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var driver in Model)
        {
            <partial name="_DriverCardPartial" model="driver" />
        }
    }
    else
    {
        <div class="col-12">
            <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                <div class="fs-1 text-muted mb-3">📭</div>
                <h4 class="fw-semibold">@Localizer["No records found"]</h4>
                <p class="text-muted">@Localizer["No information has been added here yet."]</p>
            </div>
        </div>
    }
</div>
