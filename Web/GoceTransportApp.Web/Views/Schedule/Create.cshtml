@model GoceTransportApp.Web.ViewModels.Schedules.ScheduleInputModel

@{
    ViewData["Title"] = "Create Schedule";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <i class="fas fa-calendar-plus fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">Create Schedule</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Create">
                    <input asp-for="OrganizationId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Day" class="form-label text-muted">Day</label>
                        <select asp-for="Day" class="form-select rounded-3">
                            <option value="">-- Select a Day --</option>
                            <option value="Monday">Monday</option>
                            <option value="Tuesday">Tuesday</option>
                            <option value="Wednesday">Wednesday</option>
                            <option value="Thursday">Thursday</option>
                            <option value="Friday">Friday</option>
                            <option value="Saturday">Saturday</option>
                            <option value="Sunday">Sunday</option>
                        </select>
                        <span asp-validation-for="Day" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Departure" class="form-label text-muted">Departure Time</label>
                        <input asp-for="Departure" type="time" class="form-control rounded-3" />
                        <span asp-validation-for="Departure" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Arrival" class="form-label text-muted">Arrival Time</label>
                        <input asp-for="Arrival" type="time" class="form-control rounded-3" />
                        <span asp-validation-for="Arrival" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="VehicleId" class="form-label text-muted">Vehicle</label>
                        <select asp-for="VehicleId" class="form-select rounded-3">
                            <option value="">Select a vehicle</option>
                            @foreach (var vehicle in Model.Vehicles)
                            {
                                <option value="@vehicle.Value">@vehicle.Text</option>
                            }
                        </select>
                        <span asp-validation-for="VehicleId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="RouteId" class="form-label text-muted">Route</label>
                        <select asp-for="RouteId" class="form-select rounded-3">
                            <option value="">Select a route</option>
                            @foreach (var route in Model.Routes)
                            {
                                <option value="@route.Value">@route.Text</option>
                            }
                        </select>
                        <span asp-validation-for="RouteId" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>Save
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
