@model GoceTransportApp.Web.ViewModels.Routes.EditRouteInputModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Edit Route";
    var returnUrl = Context.Request.Headers["Referer"].ToString();
    if (string.IsNullOrEmpty(returnUrl)) returnUrl = Url.Action("Index", "Route");
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="text-center mb-4">
            <i class="fas fa-route fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Edit Route"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                    <input type="hidden" asp-for="Id" />
                    <input asp-for="OrganizationId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="FromCityId" class="form-label text-muted">@Localizer["From City"]</label>
                        <select id="fromCity" asp-for="FromCityId" asp-items="@(new SelectList(Model.Cities, "Id", "Name"))" class="form-select rounded-3" onchange="loadStreets('fromCity', 'fromStreet')">
                            <option value="">@Localizer["Select a city"]</option>
                        </select>
                        <span asp-validation-for="FromCityId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FromStreetId" class="form-label text-muted">@Localizer["From Street"]</label>
                        <select id="fromStreet" asp-for="FromStreetId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a street"]</option>
                        </select>
                        <span asp-validation-for="FromStreetId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ToCityId" class="form-label text-muted">@Localizer["To City"]</label>
                        <select id="toCity" asp-for="ToCityId" asp-items="@(new SelectList(Model.Cities, "Id", "Name"))" class="form-select rounded-3" onchange="loadStreets('toCity', 'toStreet')">
                            <option value="">@Localizer["Select a city"]</option>
                        </select>
                        <span asp-validation-for="ToCityId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ToStreetId" class="form-label text-muted">@Localizer["To Street"]</label>
                        <select id="toStreet" asp-for="ToStreetId" class="form-select rounded-3">
                            <option value="">@Localizer["Select a street"]</option>
                        </select>
                        <span asp-validation-for="ToStreetId" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Distance" class="form-control rounded-3" placeholder="@Localizer["Distance (km)"]" />
                        <label asp-for="Distance">@Localizer["Distance (km)"]</label>
                        <span asp-validation-for="Distance" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Duration" type="number" min="1" class="form-control rounded-3" placeholder="@Localizer["Duration (minutes) — e.g. 135"]" />
                        <label asp-for="Duration">@Localizer["Duration (minutes) — e.g. 135"]</label>
                        <span asp-validation-for="Duration" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-save me-2"></i>@Localizer["Save Changes"]
                    </button>
                    <a href="@returnUrl" class="btn btn-outline-secondary rounded-pill w-100 mt-2">
                        <i class="fas fa-times me-2"></i>@Localizer["Cancel"]
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/loadStreetsInCity.js"></script>
    <script>
        $(document).ready(function() {
            var loadAndSetStreets = function(citySelectId, streetSelectId, streetId) {
                if ($('#' + citySelectId).val()) {
                    loadStreets(citySelectId, streetSelectId);
                    setTimeout(function() {
                        $('#' + streetSelectId).val(streetId);
                    }, 500);
                }
            };
            loadAndSetStreets('fromCity', 'fromStreet', '@Model.FromStreetId');
            loadAndSetStreets('toCity', 'toStreet', '@Model.ToStreetId');
        });
    </script>
}
