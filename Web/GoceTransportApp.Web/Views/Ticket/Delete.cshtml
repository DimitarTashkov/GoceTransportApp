@model GoceTransportApp.Web.ViewModels.Tickets.RemoveTicketViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Remove Ticket";

    var returnUrl = Context.Request.Headers["Referer"].ToString();

    if (string.IsNullOrEmpty(returnUrl))
    {
        returnUrl = Url.Action("Index", "Route");
    }
}

<h1 class="text-center mt-4 text-danger"><i class="fas fa-trash-alt"></i> @Localizer["Remove Ticket"]</h1>

<div class="row justify-content-center">
<div class="col-lg-8">
<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">
        <h5 class="card-title text-danger"><i class="fas fa-exclamation-triangle"></i> @Localizer["Confirm Deletion"]</h5>
        <p class="card-text">
            @Localizer["Are you sure you want to delete this ticket?"]
        </p>

        <div class="mb-3">
            <strong>@Localizer["Issued Date"]:</strong> @Model.IssuedDate <br />
            <strong>@Localizer["Expiry Date"]:</strong> @Model.ExpiryDate <br />
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <input asp-for="OrganizationId" type="hidden" />

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash-alt"></i> @Localizer["Confirm Delete"]
                </button>
                <a href="@returnUrl" class="btn btn-secondary"><i class="fas fa-times"></i> @Localizer["Cancel"]</a>

            </div>
        </form>
    </div>
</div>
</div>
</div>
