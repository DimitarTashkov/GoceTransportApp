@page
@model RegisterConfirmationModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Потвърдете регистрацията си";
}

<div class="row justify-content-center py-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="fas fa-envelope fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@ViewData["Title"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <p class="fs-5">Изпратихме линк за потвърждение на <strong>@Model.Email</strong>.</p>
                <p class="text-muted">Моля, проверете пощата си (и папка Спам) и кликнете на линка, за да активирате акаунта си.</p>
                <a asp-page="./Login" class="btn btn-outline-primary rounded-pill mt-3">
                    <i class="fas fa-sign-in-alt me-2"></i>Към вход
                </a>
            </div>
        </div>
    </div>
</div>
