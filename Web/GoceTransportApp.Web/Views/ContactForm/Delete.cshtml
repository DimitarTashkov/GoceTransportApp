@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.ContactForms.ContactFormDeleteViewModel
@inject IViewLocalizer Localizer

<h1>@Localizer["Delete Contact Form"]</h1>

<div>
    <p>@Localizer["Are you sure you want to delete this contact form?"]</p>
    <p><strong>@Localizer["Username"]:</strong> @Model.Username</p>
    <p><strong>@Localizer["Email"]:</strong> @Model.Email</p>
    <p><strong>@Localizer["Title"]:</strong> @Model.Title</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>
