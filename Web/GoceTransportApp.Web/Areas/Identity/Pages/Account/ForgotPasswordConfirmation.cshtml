@page
@model ForgotPasswordConfirmationModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Forgot password confirmation"].Value;
}

<div class="row justify-content-center py-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="fas fa-envelope-open-text fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Check your email"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <p class="text-muted mb-4">
                    @Localizer["If an account with that email exists, we've sent a password reset link. Please check your inbox."]
                </p>
                <a asp-page="./Login" class="btn btn-primary rounded-pill px-4">
                    <i class="fas fa-arrow-left me-1"></i>@Localizer["Back to login"]
                </a>
            </div>
        </div>
    </div>
</div>
