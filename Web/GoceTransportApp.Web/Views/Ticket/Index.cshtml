@using GoceTransportApp.Services.Data.Users
@using GoceTransportApp.Web.ViewModels.Tickets
@using System.Security.Claims
@model AllTicketsSearchFilterViewModel
@inject IUserService userService
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    ViewData["Title"] = "All Tickets";
}

<div class="text-center mb-4">
    <i class="fas fa-ticket-alt fa-3x text-primary mb-3"></i>
    <h1 class="h2 fw-bold">@Localizer["Tickets"]</h1>
</div>

<div class="d-flex gap-2 mb-4 flex-wrap align-items-center">
    <form method="get" class="d-flex gap-2 flex-grow-1 flex-wrap">
        <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control rounded-pill" placeholder="@Localizer["Search by departing or arriving city..."]" />
        <input type="date" name="FilterDate"
               value="@(Model.FilterDate.HasValue ? Model.FilterDate.Value.ToString("yyyy-MM-dd") : "")"
               class="form-control rounded-pill"
               id="filterDate" />
        <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search"></i>
        </button>
    </form>
    @if (userId != null)
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i>@Localizer["Add Ticket"]
        </a>
    }
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var ticket in Model.Tickets)
    {
        <partial name="_TicketCardPartial" model="ticket" />
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage - 1)&EntitiesPerPage=@Model.EntitiesPerPage">@Localizer["Previous"]</a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@i&EntitiesPerPage=@Model.EntitiesPerPage">@i</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?SearchQuery=@Model.SearchQuery&CurrentPage=@(Model.CurrentPage + 1)&EntitiesPerPage=@Model.EntitiesPerPage">@Localizer["Next"]</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts{
    <script src="~/js/datePlaceholderHandler.js"></script>
}
