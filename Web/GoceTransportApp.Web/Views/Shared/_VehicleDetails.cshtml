@model GoceTransportApp.Web.ViewModels.Vehicles.VehicleDetailsViewModel

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="mb-3">
            <i class="fas fa-bus fa-2x text-primary mb-2"></i>
            <h5 class="card-title fw-semibold">@Model.Number</h5>
        </div>
        <p class="card-text">
            <strong>Type:</strong> @Model.Type<br />
            <strong>Manufacturer:</strong> @Model.Manufacturer<br />
            <strong>Model:</strong> @Model.Model<br />
            <strong>Capacity:</strong> @Model.Capacity<br />
            <strong>Fuel Consumption:</strong> @(Model.FuelConsumption ?? 0) L/100km<br />
            <strong>Status:</strong> @Model.Status<br />
            <strong>Organization:</strong> @Model.OrganizationName
        </p>
    </div>
</div>
