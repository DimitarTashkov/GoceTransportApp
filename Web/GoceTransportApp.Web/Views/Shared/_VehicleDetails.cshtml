@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model GoceTransportApp.Web.ViewModels.Vehicles.VehicleDetailsViewModel

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="mb-3">
            <i class="fas fa-bus fa-2x text-primary mb-2"></i>
            <h5 class="card-title fw-semibold">@Model.Number</h5>
        </div>
        <p class="card-text">
            <strong>@Localizer["Type"]:</strong> @Model.Type<br />
            <strong>@Localizer["Manufacturer"]:</strong> @Model.Manufacturer<br />
            <strong>@Localizer["Model"]:</strong> @Model.Model<br />
            <strong>@Localizer["Capacity"]:</strong> @Model.Capacity<br />
            <strong>@Localizer["Fuel Consumption"]:</strong> @(Model.FuelConsumption ?? 0) L/100km<br />
            <strong>@Localizer["Status"]:</strong> @Model.Status<br />
            <strong>@Localizer["Organization"]:</strong> @Model.OrganizationName
        </p>
    </div>
</div>
