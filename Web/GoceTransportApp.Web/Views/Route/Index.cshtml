@using GoceTransportApp.Services.Data.Users
@using GoceTransportApp.Web.ViewModels.Routes
@using System.Security.Claims
@model AllRoutesSearchFilterViewModel
@inject IUserService userService

@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

@{
    ViewData["Title"] = "All Routes";
}


<div class="text-center mb-4">
    <i class="fas fa-route fa-3x text-primary mb-3"></i>
    <h1 class="h2 fw-bold">Routes</h1>
</div>

<div class="d-flex gap-2 mb-4 flex-wrap align-items-center">
    <form method="get" class="d-flex gap-2 flex-grow-1 flex-wrap">
        <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control rounded-pill" placeholder="Search by street or city..." />
        <input type="text" name="DepartingCityFilter" value="@Model.DepartingCityFilter" class="form-control rounded-pill" placeholder="Departing city..." />
        <input type="text" name="ArrivingCityFilter" value="@Model.ArrivingCityFilter" class="form-control rounded-pill" placeholder="Arriving city..." />
        <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search"></i>
        </button>
    </form>
    @if (userId != null)
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i>Add Route
        </a>
    }
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-2">
        @if (Model.Routes.Any())
        {
            @foreach (var route in Model.Routes)
            {
                <partial name="_RouteCardPartial" model="route" />
            }
        }
        else
        {
            <p class="text-center">No routes found.</p>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="?SearchQuery=@Model.SearchQuery&DepartingCityFilter=@Model.DepartingCityFilter&ArrivingCityFilter=@Model.ArrivingCityFilter&CurrentPage=@(Model.CurrentPage - 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                        <a class="page-link" href="?SearchQuery=@Model.SearchQuery&DepartingCityFilter=@Model.DepartingCityFilter&ArrivingCityFilter=@Model.ArrivingCityFilter&CurrentPage=@i&EntitiesPerPage=@Model.EntitiesPerPage">@i</a>
                    </li>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="?SearchQuery=@Model.SearchQuery&DepartingCityFilter=@Model.DepartingCityFilter&ArrivingCityFilter=@Model.ArrivingCityFilter&CurrentPage=@(Model.CurrentPage + 1)&EntitiesPerPage=@Model.EntitiesPerPage">
                            <i class="fas fa-chevron-right"></i> Next
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
