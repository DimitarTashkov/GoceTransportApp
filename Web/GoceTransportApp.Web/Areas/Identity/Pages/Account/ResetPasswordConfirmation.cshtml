@page
@model ResetPasswordConfirmationModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Password reset"].Value;
}

<div class="row justify-content-center py-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Password reset"]</h1>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <p class="text-muted mb-4">
                    @Localizer["Your password has been reset. You can now sign in with your new password."]
                </p>
                <a asp-page="./Login" class="btn btn-primary rounded-pill px-4">
                    <i class="fas fa-sign-in-alt me-1"></i>@Localizer["Log in"]
                </a>
            </div>
        </div>
    </div>
</div>
