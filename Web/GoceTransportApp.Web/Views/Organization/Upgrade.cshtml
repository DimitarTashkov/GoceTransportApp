@using Microsoft.AspNetCore.Mvc.Localization
@using static GoceTransportApp.Common.GlobalConstants.TempDataKeys
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Pricing & Plans";
    var upgradeReason = TempData[UpgradeReason]?.ToString();
}

<section class="py-5">
    <div class="text-center mb-5">
        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3 fw-semibold">
            <i class="fas fa-gem me-1"></i>@Localizer["Pricing"]
        </span>
        <h1 class="display-5 fw-bold">@Localizer["Choose Your Plan"]</h1>
        <p class="lead text-muted col-lg-7 mx-auto">@Localizer["Unlock more organizations and features for your transport business."]</p>

        <div class="alert alert-info d-flex align-items-start gap-2 rounded-3 px-4 mt-3 text-start col-lg-8 mx-auto" role="alert">
            <i class="fas fa-info-circle mt-1 flex-shrink-0"></i>
            <span>@Localizer["GoceTransportApp is a volunteer, non-profit project. All revenue from paid plans is used solely to cover monthly server hosting costs of approximately €20. Support us to keep the platform alive!"]</span>
        </div>

        @if (!string.IsNullOrEmpty(upgradeReason))
        {
            <div class="alert alert-warning d-inline-flex align-items-center gap-2 rounded-3 px-4 mt-3" role="alert">
                <i class="fas fa-lock me-1"></i> @upgradeReason
            </div>
        }

        <div class="d-inline-flex align-items-center gap-3 mt-4 bg-body-secondary rounded-pill px-4 py-2 shadow-sm">
            <span class="fw-semibold small text-primary" id="monthlyLabel">@Localizer["Monthly"]</span>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="billingToggle" style="width:2.8rem;height:1.4rem;cursor:pointer;">
            </div>
            <span class="fw-semibold small" id="annualLabel">
                @Localizer["Annual"]
                <span class="badge bg-success ms-1 rounded-pill" style="font-size:0.7rem;">@Localizer["Save ~17%"]</span>
            </span>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 justify-content-center mb-5">

        @* Free *@
        <div class="col">
            <div class="card border-0 rounded-4 shadow-sm h-100 text-center">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="rounded-circle bg-secondary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="fas fa-paper-plane fa-xl text-secondary"></i>
                    </div>
                    <h3 class="fw-bold">Free</h3>
                    <p class="text-muted small mb-3">@Localizer["For individual operators"]</p>
                    <div class="display-5 fw-bolder mb-1">€0<small class="fs-6 text-muted fw-normal">/mo</small></div>
                    <p class="text-muted small mb-4">@Localizer["Forever free"]</p>

                    <ul class="list-unstyled text-start mb-4 flex-grow-1">
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>1</strong> @Localizer["Organization"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>2</strong> @Localizer["Routes"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>5</strong> @Localizer["Schedules"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Basic Analytics"]</li>
                        <li class="mb-2 py-1 text-muted"><i class="fas fa-times-circle text-muted me-2"></i>@Localizer["Real-Time Notifications"]</li>
                        <li class="mb-2 py-1 text-muted"><i class="fas fa-times-circle text-muted me-2"></i>@Localizer["Live Status Alerts"]</li>
                        <li class="mb-2 py-1 text-muted"><i class="fas fa-times-circle text-muted me-2"></i>@Localizer["Google Maps Coordinates"]</li>
                        <li class="mb-2 py-1 text-muted"><i class="fas fa-times-circle text-muted me-2"></i>@Localizer["Priority Support"]</li>
                    </ul>

                    <button class="btn btn-outline-secondary rounded-pill w-100 py-2" disabled>
                        <i class="fas fa-check me-1"></i>@Localizer["Current Plan"]
                    </button>
                </div>
            </div>
        </div>

        @* Starter *@
        <div class="col">
            <div class="card border-success border-2 rounded-4 shadow-sm h-100 text-center">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="fas fa-seedling fa-xl text-success"></i>
                    </div>
                    <h3 class="fw-bold text-success">Starter</h3>
                    <p class="text-muted small mb-3">@Localizer["For small operators"]</p>
                    <div class="display-5 fw-bolder mb-1">€<span class="price-amount" data-monthly="6.99" data-annual="4.58">6.99</span><small class="fs-6 text-muted fw-normal">/mo</small></div>
                    <p class="text-muted small mb-4 price-note" data-monthly="@Localizer["Billed monthly"]" data-annual="@Localizer["Billed annually (€54.99/yr)"]">@Localizer["Billed monthly"]</p>

                    <ul class="list-unstyled text-start mb-4 flex-grow-1">
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>2</strong> @Localizer["Organizations"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>10</strong> @Localizer["Routes"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>30</strong> @Localizer["Schedules"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Extended Analytics"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Real-Time Notifications"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Live Status Alerts"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Google Maps Coordinates"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Email Support (48h)"]</li>
                    </ul>

                    <a asp-controller="ContactForm" asp-action="Create" class="btn btn-success rounded-pill w-100 py-2 fw-semibold">
                        <i class="fas fa-envelope me-1"></i>@Localizer["Contact Us"]
                    </a>
                </div>
            </div>
        </div>

        @* Pro *@
        <div class="col">
            <div class="card border-primary border-2 rounded-4 shadow h-100 text-center position-relative">
                <div class="position-absolute top-0 start-50 translate-middle">
                    <span class="badge bg-primary rounded-pill px-4 py-2 fs-6">
                        <i class="fas fa-star me-1"></i>@Localizer["Most Popular"]
                    </span>
                </div>
                <div class="card-body p-4 pt-5 d-flex flex-column">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="fas fa-rocket fa-xl text-primary"></i>
                    </div>
                    <h3 class="fw-bold text-primary">Pro</h3>
                    <p class="text-muted small mb-3">@Localizer["For growing businesses"]</p>
                    <div class="display-5 fw-bolder mb-1">€<span class="price-amount" data-monthly="14.99" data-annual="10.41">14.99</span><small class="fs-6 text-muted fw-normal">/mo</small></div>
                    <p class="text-muted small mb-4 price-note" data-monthly="@Localizer["Billed monthly"]" data-annual="@Localizer["Billed annually (€124.99/yr)"]">@Localizer["Billed monthly"]</p>

                    <ul class="list-unstyled text-start mb-4 flex-grow-1">
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>5</strong> @Localizer["Organizations"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>@Localizer["Unlimited"]</strong> @Localizer["Routes"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>@Localizer["Unlimited"]</strong> @Localizer["Schedules"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Full Analytics + Export"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Real-Time Notifications"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Live Status Alerts"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Google Maps Coordinates"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Email Support (24h)"]</li>
                    </ul>

                    <a asp-controller="ContactForm" asp-action="Create" class="btn btn-primary rounded-pill w-100 py-2 fw-semibold">
                        <i class="fas fa-envelope me-1"></i>@Localizer["Contact Us"]
                    </a>
                </div>
            </div>
        </div>

        @* Enterprise *@
        <div class="col">
            <div class="card border-0 rounded-4 shadow-sm h-100 text-center">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="fas fa-crown fa-xl text-warning"></i>
                    </div>
                    <h3 class="fw-bold">Enterprise</h3>
                    <p class="text-muted small mb-3">@Localizer["For large fleets"]</p>
                    <div class="display-5 fw-bolder mb-1">€<span class="price-amount" data-monthly="28.99" data-annual="20.00">28.99</span><small class="fs-6 text-muted fw-normal">/mo</small></div>
                    <p class="text-muted small mb-4 price-note" data-monthly="@Localizer["Billed monthly"]" data-annual="@Localizer["Billed annually (€239.99/yr)"]">@Localizer["Billed monthly"]</p>

                    <ul class="list-unstyled text-start mb-4 flex-grow-1">
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>@Localizer["Unlimited"]</strong> @Localizer["Organizations"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>@Localizer["Unlimited"]</strong> @Localizer["Routes"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i><strong>@Localizer["Unlimited"]</strong> @Localizer["Schedules"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Full Analytics + API"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Real-Time Notifications"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Live Status Alerts"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Google Maps Coordinates"]</li>
                        <li class="mb-2 py-1"><i class="fas fa-check-circle text-success me-2"></i>@Localizer["Phone + Chat Support (4h)"]</li>
                    </ul>

                    <a asp-controller="ContactForm" asp-action="Create" class="btn btn-warning rounded-pill w-100 py-2 fw-semibold text-dark">
                        <i class="fas fa-envelope me-1"></i>@Localizer["Contact Us"]
                    </a>
                </div>
            </div>
        </div>

    </div>

    <!-- Comparison Table -->
    <div class="card border-0 shadow-sm rounded-4 p-4 p-lg-5 mb-4">
        <h4 class="fw-bold text-center mb-4">@Localizer["Compare Plans"]</h4>
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0">
                <thead>
                    <tr>
                        <th class="text-muted small fw-semibold" style="width:30%;">@Localizer["Feature"]</th>
                        <th class="text-center small fw-semibold">Free</th>
                        <th class="text-center small fw-semibold text-success">Starter</th>
                        <th class="text-center small fw-semibold text-primary">Pro</th>
                        <th class="text-center small fw-semibold text-warning">Enterprise</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="small">@Localizer["Organizations"]</td>
                        <td class="text-center">1</td>
                        <td class="text-center fw-semibold text-success">2</td>
                        <td class="text-center fw-semibold text-primary">5</td>
                        <td class="text-center fw-semibold">@Localizer["Unlimited"]</td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Routes"]</td>
                        <td class="text-center">2</td>
                        <td class="text-center fw-semibold text-success">10</td>
                        <td class="text-center fw-semibold text-primary">@Localizer["Unlimited"]</td>
                        <td class="text-center fw-semibold">@Localizer["Unlimited"]</td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Schedules"]</td>
                        <td class="text-center">5</td>
                        <td class="text-center fw-semibold text-success">30</td>
                        <td class="text-center fw-semibold text-primary">@Localizer["Unlimited"]</td>
                        <td class="text-center fw-semibold">@Localizer["Unlimited"]</td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Analytics Dashboard"]</td>
                        <td class="text-center"><span class="text-muted small">@Localizer["Basic"]</span></td>
                        <td class="text-center"><span class="text-success small">@Localizer["Extended"]</span></td>
                        <td class="text-center"><span class="text-primary small">@Localizer["Full + Export"]</span></td>
                        <td class="text-center"><span class="text-warning small">@Localizer["Full + API"]</span></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Real-Time Notifications"]</td>
                        <td class="text-center"><i class="fas fa-times text-muted"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Live Status Alerts"]</td>
                        <td class="text-center"><i class="fas fa-times text-muted"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Google Maps Coordinates"]</td>
                        <td class="text-center"><i class="fas fa-times text-muted"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                        <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    </tr>
                    <tr>
                        <td class="small">@Localizer["Support"]</td>
                        <td class="text-center"><span class="text-muted small">@Localizer["Basic"]</span></td>
                        <td class="text-center"><span class="text-success small">@Localizer["Email (48h)"]</span></td>
                        <td class="text-center"><span class="text-primary small">@Localizer["Email (24h)"]</span></td>
                        <td class="text-center"><span class="text-warning small">@Localizer["Phone + Chat (4h)"]</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-center">
        <a asp-area="" asp-controller="Organization" asp-action="Index" class="btn btn-link text-muted text-decoration-none">
            <i class="fas fa-arrow-left me-1"></i>@Localizer["Back to Organizations"]
        </a>
    </div>
</section>

@section Scripts {
<script>
    (function () {
        var toggle = document.getElementById('billingToggle');
        var monthlyLabel = document.getElementById('monthlyLabel');
        var annualLabel = document.getElementById('annualLabel');

        toggle.addEventListener('change', function () {
            var mode = toggle.checked ? 'annual' : 'monthly';
            document.querySelectorAll('.price-amount').forEach(function (el) {
                el.textContent = el.dataset[mode];
            });
            document.querySelectorAll('.price-note').forEach(function (el) {
                el.textContent = el.dataset[mode];
            });
            monthlyLabel.classList.toggle('text-primary', !toggle.checked);
            annualLabel.classList.toggle('text-primary', toggle.checked);
        });
    })();
</script>
}
