@using GoceTransportApp.Services.Data.Users
@using System.Security.Claims
@using static GoceTransportApp.Common.GlobalConstants
@using Microsoft.AspNetCore.Mvc.Localization
@model GoceTransportApp.Web.ViewModels.Cities.CityDetailsViewModel
@inject IUserService userService
@inject IViewLocalizer Localizer
@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAdmin = User.IsInRole(AdministratorRoleName);
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <h2 class="card-title text-center fw-bold mb-4">@Model.Name</h2>

        <div class="mb-3">
            <h6 class="text-muted text-uppercase small fw-semibold">@Localizer["State"]</h6>
            <p class="card-text">@Model.State</p>
        </div>

        <div class="mb-3">
            <h6 class="text-muted text-uppercase small fw-semibold">@Localizer["Zip Code"]</h6>
            <p class="card-text">@Model.ZipCode</p>
        </div>

        <div class="mb-3">
            <h6 class="text-muted text-uppercase small fw-semibold">@Localizer["Streets"]</h6>
            @if (Model.Streets != null && Model.Streets.Any())
            {
                <div class="list-group list-group-flush rounded-3">
                    @foreach (var street in Model.Streets)
                    {
                        <div class="list-group-item border-0 px-0">
                            <i class="fas fa-road text-muted me-2"></i>@street.Name
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">@Localizer["No streets available for this city."]</p>
            }
        </div>

        <div class="d-flex flex-column gap-2 mt-4">
            @if (userId != null)
            {
                <a asp-action="AddStreet" asp-route-id="@Model.Id" class="btn btn-outline-success rounded-pill w-100">
                    <i class="fas fa-plus"></i> @Localizer["Add Streets"]
                </a>
            }
            @if (isAdmin)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning rounded-pill w-100">
                    <i class="fas fa-edit"></i> @Localizer["Edit"]
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger rounded-pill w-100">
                    <i class="fas fa-trash-alt"></i> @Localizer["Delete"]
                </a>
            }
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill w-100">
                <i class="fas fa-arrow-left"></i> @Localizer["Back"]
            </a>
        </div>
    </div>
</div>
