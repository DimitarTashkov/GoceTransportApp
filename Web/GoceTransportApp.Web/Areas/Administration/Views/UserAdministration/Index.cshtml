@using GoceTransportApp.Data.Models
@using GoceTransportApp.Web.ViewModels.Users
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@model AllUsersSearchFilterViewModel

@inject RoleManager<ApplicationRole> roleManager

@{
    IEnumerable<string?> allRoles = await roleManager.Roles
        .Select(r => r.Name)
        .ToArrayAsync();
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong><i class="fas fa-check-circle me-2"></i></strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["FailMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong><i class="fas fa-times-circle me-2"></i></strong> @TempData["FailMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="text-center mb-4">
    <i class="fas fa-users fa-3x text-primary mb-3"></i>
    <h1 class="h2 fw-bold">User Management</h1>
</div>

<div class="d-flex gap-2 mb-4">
    <form method="get" class="d-flex gap-2 flex-grow-1">
        <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control rounded-pill" placeholder="Search for user..." />
        <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search"></i>
        </button>
    </form>
</div>

<div class="table-responsive bg-white rounded-4 shadow-sm p-3">
    <table class="table table-borderless table-hover align-middle mb-0">
        <thead>
            <tr>
                <th><i class="fas fa-envelope me-2"></i>Email</th>
                <th><i class="fas fa-user-tag me-2"></i>Roles</th>
                <th><i class="fas fa-tools me-2"></i>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td><i class="fas fa-user me-2 text-muted"></i>@user.Email</td>
                    <td>
                        @foreach (var role in user.Roles)
                        {
                            <span class="badge bg-secondary me-1"><i class="fas fa-tag me-1"></i>@role</span>
                        }
                    </td>
                    <td>
                        <form method="post" asp-action="AssignRole" asp-controller="UserAdministration" asp-area="Administration" class="d-inline">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-select form-select-sm d-inline w-auto">
                                @foreach (string role in allRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm rounded-pill ms-1">
                                <i class="fas fa-plus-circle me-1"></i>Assign
                            </button>
                        </form>

                        <form method="post" asp-action="RemoveRole" asp-controller="UserAdministration" asp-area="Administration" class="d-inline ms-2">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-select form-select-sm d-inline w-auto">
                                @foreach (var role in user.Roles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-outline-warning btn-sm rounded-pill ms-1">
                                <i class="fas fa-minus-circle me-1"></i>Remove
                            </button>
                        </form>

                        <form method="post" asp-action="DeleteUser" asp-controller="UserAdministration" asp-area="Administration" class="d-inline ms-2">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
