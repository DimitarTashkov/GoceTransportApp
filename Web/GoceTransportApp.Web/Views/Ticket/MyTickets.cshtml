@model GoceTransportApp.Web.ViewModels.Tickets.MyTicketsViewModel
@using static GoceTransportApp.Common.ResultMessages.GeneralMessages
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "My Trips";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <i class="fas fa-ticket-alt fa-2x text-primary"></i>
    <h2 class="fw-bold mb-0">@Localizer["My Trips"]</h2>
</div>

@if (TempData[nameof(SuccessMessage)] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData[nameof(SuccessMessage)]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData[nameof(FailMessage)] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData[nameof(FailMessage)]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h4 class="fw-semibold mb-3"><i class="fas fa-calendar-check text-primary me-2"></i>@Localizer["Upcoming Trips"]</h4>

@if (Model.Upcoming.Any())
{
    <div class="row g-3 mb-5">
        @foreach (var ticket in Model.Upcoming)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 hover-elevate">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-primary rounded-pill px-3 py-2">@ticket.Day</span>
                            <span class="fw-bold text-primary">@ticket.Price €</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="fas fa-map-marker-alt text-primary"></i>
                            <span class="fw-semibold">@ticket.FromCity</span>
                            <i class="fas fa-arrow-right text-muted mx-1"></i>
                            <span class="fw-semibold">@ticket.ToCity</span>
                        </div>
                        <div class="d-flex align-items-center gap-4 text-muted small mb-2">
                            <span><i class="fas fa-plane-departure me-1"></i>@ticket.DepartingTime</span>
                            <span><i class="fas fa-plane-arrival me-1"></i>@ticket.ArrivingTime</span>
                        </div>
                        <p class="text-muted small mb-0"><i class="fas fa-building me-1"></i>@ticket.OrganizationName</p>
                    </div>
                    @if (ticket.CanCancel)
                    {
                        <div class="card-footer bg-transparent border-0 pb-3 px-4">
                            <form asp-action="Cancel" asp-controller="Ticket" method="post">
                                <input type="hidden" name="ticketId" value="@ticket.TicketId" />
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill w-100"
                                        onclick="return confirm('@Localizer["Are you sure you want to cancel this ticket?"]')">
                                    <i class="fas fa-times-circle me-1"></i>@Localizer["Cancel Ticket"]
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="card-footer bg-transparent border-0 pb-3 px-4">
                            <span class="text-muted small"><i class="fas fa-lock me-1"></i>@Localizer["Cancellation not available (less than 24h)"]</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-4 mb-5">
        <i class="fas fa-calendar-times fa-2x text-muted mb-2"></i>
        <p class="text-muted">@Localizer["No upcoming trips."]</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-search me-1"></i>@Localizer["Find a Trip"]
        </a>
    </div>
}

<hr class="my-4">

<h4 class="fw-semibold mb-3"><i class="fas fa-history text-secondary me-2"></i>@Localizer["Past Trips"]</h4>

@if (Model.Past.Any())
{
    <div class="row g-3">
        @foreach (var ticket in Model.Past)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 opacity-75">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-secondary rounded-pill px-3 py-2">@ticket.Day</span>
                            <span class="fw-bold text-secondary">@ticket.Price €</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="fas fa-map-marker-alt text-secondary"></i>
                            <span class="fw-semibold">@ticket.FromCity</span>
                            <i class="fas fa-arrow-right text-muted mx-1"></i>
                            <span class="fw-semibold">@ticket.ToCity</span>
                        </div>
                        <div class="d-flex align-items-center gap-4 text-muted small mb-2">
                            <span><i class="fas fa-plane-departure me-1"></i>@ticket.DepartingTime</span>
                            <span><i class="fas fa-plane-arrival me-1"></i>@ticket.ArrivingTime</span>
                        </div>
                        <p class="text-muted small mb-0"><i class="fas fa-building me-1"></i>@ticket.OrganizationName</p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-4">
        <i class="fas fa-inbox fa-2x text-muted mb-2"></i>
        <p class="text-muted">@Localizer["No past trips yet."]</p>
    </div>
}

@if (TempData["PurchaseFrom"] != null)
{
    <div id="purchaseToastData"
         data-from="@TempData["PurchaseFrom"]"
         data-to="@TempData["PurchaseTo"]"
         data-org="@TempData["PurchaseOrg"]"
         style="display:none;"></div>
    <script src="~/js/purchaseToast.js" asp-append-version="true"></script>
}
