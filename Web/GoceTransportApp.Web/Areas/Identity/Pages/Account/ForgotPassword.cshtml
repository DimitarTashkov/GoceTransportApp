@page
@model ForgotPasswordModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Forgot password"].Value;
}

<div class="row justify-content-center py-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="fas fa-key fa-3x text-primary mb-3"></i>
            <h1 class="h3 fw-bold">@Localizer["Forgot your password?"]</h1>
            <p class="text-muted">@Localizer["Enter your email and we'll send you a reset link."]</p>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="email" placeholder="name@example.com" />
                        <label asp-for="Input.Email">@Localizer["Email"]</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-paper-plane me-2"></i>@Localizer["Send reset link"]
                    </button>

                    <p class="text-center mt-4 mb-0 text-muted small">
                        <a asp-page="./Login" class="text-primary fw-semibold">
                            <i class="fas fa-arrow-left me-1"></i>@Localizer["Back to login"]
                        </a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
